<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seller Dashboard - Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }
        * { box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--gray-100); color: var(--black); margin: 0; }
        .topbar { background: var(--purple-deep); padding: 0; position: sticky; top: 0; z-index: 1000; box-shadow: 0 2px 16px rgba(59,7,100,0.4); }
        .topbar .container { display: flex; align-items: center; gap: 16px; padding: 12px 24px; }
        .navbar-brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--white) !important; text-decoration: none; display: flex; align-items: center; gap: 6px; }
        .navbar-brand .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .nav-right { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0 0 0 auto; padding: 0; }
        .user-chip { text-decoration: none; background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.4); color: var(--white) !important; border-radius: 20px; padding: 5px 14px; font-size: 0.85rem; font-weight: 600; }
        .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8) !important; border-radius: 8px; padding: 5px 12px; font-size: 0.83rem; text-decoration: none; }
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        .page-wrap { max-width: 1200px; margin: 32px auto; padding: 0 20px 60px; }

        /* Page header */
        .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
        .page-header h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--black); margin-bottom: 4px; }
        .page-header p { color: var(--gray-500); font-size: 0.88rem; }
        .btn-add { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 11px 22px; font-size: 0.88rem; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; transition: background 0.2s; }
        .btn-add:hover { background: var(--purple-mid); color: var(--white); }

        /* Stats grid */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
        .stat-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); padding: 20px 22px; }
        .stat-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
        .stat-label { font-size: 0.72rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.5px; }
        .stat-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.05rem; }
        .si-purple { background: var(--purple-pale); color: var(--purple-mid); }
        .si-green  { background: #f0fdf4; color: #16a34a; }
        .si-amber  { background: #fffbeb; color: #d97706; }
        .si-blue   { background: #eff6ff; color: #2563eb; }
        .stat-value { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.8rem; color: var(--black); line-height: 1; }
        .stat-sub { font-size: 0.72rem; color: var(--gray-500); margin-top: 6px; }

        /* Fee breakdown */
        .fee-info { background: linear-gradient(135deg, var(--purple-deep), var(--purple-mid)); border-radius: 14px; padding: 22px 24px; margin-bottom: 28px; color: var(--white); display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
        .fee-item .fee-label { font-size: 0.72rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
        .fee-item .fee-value { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.2rem; }
        .fee-item .fee-note { font-size: 0.75rem; opacity: 0.65; margin-top: 3px; }

        /* Section */
        .section-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); overflow: hidden; margin-bottom: 24px; }
        .section-head { padding: 16px 22px; border-bottom: 1.5px solid var(--gray-200); display: flex; align-items: center; justify-content: space-between; }
        .section-head h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 0.95rem; color: var(--black); margin: 0; display: flex; align-items: center; gap: 7px; }
        .section-head h3 i { color: var(--purple-mid); }
        .count-tag { background: var(--purple-pale); color: var(--purple-mid); font-size: 0.7rem; font-weight: 700; border-radius: 20px; padding: 2px 10px; }

        /* Products table */
        table { width: 100%; border-collapse: collapse; }
        th { padding: 10px 18px; text-align: left; font-size: 0.68rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.5px; background: var(--gray-100); border-bottom: 1.5px solid var(--gray-200); white-space: nowrap; }
        td { padding: 12px 18px; font-size: 0.84rem; border-bottom: 1px solid var(--gray-200); color: var(--black); vertical-align: middle; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: var(--gray-100); }
        .td-id { color: var(--gray-500); font-family: monospace; font-size: 0.78rem; }
        .td-bold { font-weight: 600; }
        .td-amount { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.88rem; color: var(--purple-mid); }
        .td-green { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.88rem; color: #16a34a; }
        .td-red   { font-size: 0.82rem; color: #dc2626; }
        .badge { display: inline-flex; align-items: center; gap: 4px; font-size: 0.65rem; font-weight: 700; border-radius: 6px; padding: 3px 9px; text-transform: uppercase; letter-spacing: 0.3px; }
        .b-active   { background: #f0fdf4; color: #15803d; border: 1px solid #86efac; }
        .b-inactive { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
        .b-delivered { background: #f0fdf4; color: #15803d; border: 1px solid #86efac; }
        .b-pending   { background: #fffbeb; color: #92400e; border: 1px solid #fcd34d; }
        .b-shipped   { background: #ecfeff; color: #0e7490; border: 1px solid #a5f3fc; }
        .b-processing { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }

        .btn-tbl { border: none; border-radius: 6px; padding: 5px 12px; font-size: 0.75rem; font-weight: 700; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.15s; display: inline-flex; align-items: center; gap: 5px; text-decoration: none; }
        .btn-tbl-purple { background: var(--purple-pale); color: var(--purple-mid); border: 1px solid rgba(109,40,217,0.2); }
        .btn-tbl-purple:hover { background: var(--purple-mid); color: var(--white); }
        .btn-tbl-view { background: var(--gray-100); color: var(--gray-500); border: 1px solid var(--gray-200); }
        .btn-tbl-view:hover { background: var(--gray-200); color: var(--black); }

        /* Product thumbnail */
        .prod-thumb { width: 44px; height: 44px; object-fit: cover; border-radius: 8px; border: 1.5px solid var(--gray-200); }
        .prod-thumb-ph { width: 44px; height: 44px; background: var(--gray-100); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--gray-200); font-size: 1.2rem; border: 1.5px solid var(--gray-200); }

        /* Empty */
        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-state i { font-size: 3rem; color: var(--gray-200); display: block; margin-bottom: 14px; }
        .empty-state h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--black); margin-bottom: 6px; }
        .empty-state p { color: var(--gray-500); font-size: 0.85rem; }

        /* Wallet card */
        .wallet-card { background: linear-gradient(135deg, #16a34a, #15803d); border-radius: 14px; padding: 22px 24px; margin-bottom: 28px; color: var(--white); display: flex; align-items: center; justify-content: space-between; }
        .wallet-card .wl-label { font-size: 0.78rem; opacity: 0.8; margin-bottom: 4px; }
        .wallet-card .wl-amount { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem; }
        .wallet-card .wl-note { font-size: 0.78rem; opacity: 0.7; margin-top: 4px; }
        .wallet-icon { width: 52px; height: 52px; background: rgba(255,255,255,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }

        footer { background: var(--purple-deep); color: rgba(255,255,255,0.6); text-align: center; padding: 24px; font-size: 0.85rem; margin-top: 48px; }
        footer strong { color: var(--purple-light); }

        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .fee-info { grid-template-columns: 1fr; }
        }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <ul class="nav-right">
            <li><a class="nav-link-plain" href="/">Home</a></li>
            <li><a class="nav-link-plain" href="/profile">My Account</a></li>
            <li><a href="/profile" class="user-chip"><%= user.username %></a></li>
            <li><a href="/logout" class="btn-logout">Logout</a></li>
        </ul>
    </div>
</nav>

<div class="page-wrap">


    <div class="page-header">
        <div>
            <h1>Seller Dashboard</h1>
            <p>Manage your listings and track your earnings.</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <a href="/add-product" class="btn-add"><i class="bi bi-plus-circle-fill"></i> Add New Product</a>
            <a href="/seller/preview" class="btn-add" style="background:transparent;color:var(--purple-mid);border:1.5px solid var(--purple-mid);"><i class="bi bi-shop"></i> Storefront Description</a>
        </div>
    </div>


    <div class="wallet-card">
        <div>
            <div class="wl-label">Available Wallet Balance</div>
            <div class="wl-amount">₦<%= wallet %></div>
            <div class="wl-note">Your net earnings are credited here after each sale</div>
        </div>
        <div class="wallet-icon"><i class="bi bi-wallet2"></i></div>
    </div>


    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-top"><span class="stat-label">Total Gross</span><span class="stat-icon si-purple"><i class="bi bi-graph-up"></i></span></div>
            <div class="stat-value" style="font-size:1.4rem;">₦<%= totalGross %></div>
            <div class="stat-sub">Before fees &amp; deductions</div>
        </div>
        <div class="stat-card">
            <div class="stat-top"><span class="stat-label">Platform Fees</span><span class="stat-icon si-amber"><i class="bi bi-percent"></i></span></div>
            <div class="stat-value" style="font-size:1.4rem; color:#d97706;">₦<%= totalFees %></div>
            <div class="stat-sub"><%= platformFeePct %>% per transaction</div>
        </div>
        <div class="stat-card">
            <div class="stat-top"><span class="stat-label">Net Earnings</span><span class="stat-icon si-green"><i class="bi bi-cash-stack"></i></span></div>
            <div class="stat-value" style="font-size:1.4rem; color:#16a34a;">₦<%= totalNet %></div>
            <div class="stat-sub">Credited to wallet</div>
        </div>
        <div class="stat-card">
            <div class="stat-top"><span class="stat-label">Products</span><span class="stat-icon si-blue"><i class="bi bi-box-seam"></i></span></div>
            <div class="stat-value"><%= products.length %></div>
            <div class="stat-sub"><%= products.filter(p=>p.available).length %> active listings</div>
        </div>
    </div>


    <div class="fee-info">
        <div class="fee-item">
            <div class="fee-label">Platform Fee</div>
            <div class="fee-value"><%= platformFeePct %>%</div>
            <div class="fee-note">Deducted from each sale</div>
        </div>
        <div class="fee-item">
            <div class="fee-label">Shipping Deduction</div>
            <div class="fee-value">₦<%= shippingDeduction %></div>
            <div class="fee-note">Per order (split across sellers)</div>
        </div>
        <div class="fee-item">
            <div class="fee-label">Net Formula</div>
            <div class="fee-value" style="font-size:0.95rem; font-family:'DM Sans',sans-serif; font-weight:600;">Gross − 5% − Shipping</div>
            <div class="fee-note">Credited to your wallet</div>
        </div>
    </div>


    <div class="section-card">
        <div class="section-head">
            <h3><i class="bi bi-box-seam"></i> Your Products</h3>
            <span class="count-tag"><%= products.length %> listings</span>
        </div>
        <% if (products.length === 0) { %>
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <h3>No products yet</h3>
                <p>Add your first product to start selling.</p>
            </div>
        <% } else { %>
        <div style="overflow-x:auto;">
            <table>
                <thead>
                    <tr><th></th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% products.forEach(p => { %>
                    <tr>
                        <td>
                            <% if (p.image && p.image !== '') { %>
                                <img src="<%= p.image %>" alt="<%= p.name %>" class="prod-thumb">
                            <% } else { %>
                                <div class="prod-thumb-ph"><i class="bi bi-image"></i></div>
                            <% } %>
                        </td>
                        <td class="td-bold"><%= p.name %></td>
                        <td><span style="font-size:0.78rem;background:var(--gray-100);border-radius:4px;padding:2px 8px;color:var(--gray-500);"><%= p.category %></span></td>
                        <td class="td-amount">₦<%= parseFloat(p.price).toLocaleString() %></td>
                        <td><%= p.stock || 0 %> units</td>
                        <td>
                            <% if (p.available) { %>
                                <span class="badge b-active"><i class="bi bi-eye"></i> Active</span>
                            <% } else { %>
                                <span class="badge b-inactive"><i class="bi bi-eye-slash"></i> Hidden</span>
                            <% } %>
                        </td>
                        <td style="display:flex;gap:6px;">
                            <a href="/edit-product/<%= p.id %>" class="btn-tbl btn-tbl-purple"><i class="bi bi-pencil-square"></i> Edit</a>
                            <a href="/product/<%= p.id %>" class="btn-tbl btn-tbl-view"><i class="bi bi-eye"></i> View</a>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>


    <div class="section-card">
        <div class="section-head">
            <h3><i class="bi bi-receipt"></i> Earnings History</h3>
            <span class="count-tag"><%= earnings.length %> transactions</span>
        </div>
        <% if (earnings.length === 0) { %>
            <div class="empty-state">
                <i class="bi bi-receipt"></i>
                <h3>No earnings yet</h3>
                <p>Your earnings will appear here once you receive your first order.</p>
            </div>
        <% } else { %>
        <div style="overflow-x:auto;">
            <table>
                <thead>
                    <tr><th>Order #</th><th>Date</th><th>Gross</th><th>Platform Fee</th><th>Shipping</th><th>Net Earned</th><th>Order Status</th></tr>
                </thead>
                <tbody>
                    <% earnings.forEach(e => { %>
                    <tr>
                        <td class="td-id">#<%= e.order_id %></td>
                        <td style="font-size:0.8rem;color:var(--gray-500);">
                            <%= new Date(e.order_date).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) %>
                        </td>
                        <td class="td-amount">₦<%= parseFloat(e.gross_amount).toFixed(2) %></td>
                        <td class="td-red">−₦<%= parseFloat(e.platform_fee).toFixed(2) %></td>
                        <td class="td-red">−₦<%= parseFloat(e.shipping_deduction).toFixed(2) %></td>
                        <td class="td-green">₦<%= parseFloat(e.net_amount).toFixed(2) %></td>
                        <td>
                            <span class="badge b-<%= e.order_status %>"><%= e.order_status ? e.order_status.toUpperCase() : 'PENDING' %></span>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>

</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
