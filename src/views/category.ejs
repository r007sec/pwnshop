<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= currentCategory ? currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1) : 'Categories' %> - Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }
        * { box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--gray-100); color: var(--black); margin: 0; }

        /* ── NAVBAR ── */
        .topbar { background: var(--purple-deep); padding: 0; position: sticky; top: 0; z-index: 1000; box-shadow: 0 2px 16px rgba(59,7,100,0.4); }
        .topbar .container { display: flex; align-items: center; gap: 16px; padding: 12px 24px; }
        .navbar-brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--white) !important; text-decoration: none; display: flex; align-items: center; gap: 6px; white-space: nowrap; }
        .navbar-brand .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .nav-links { display: flex; gap: 4px; list-style: none; margin: 0; padding: 0; }
        .nav-links .nav-link { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; font-weight: 500; padding: 6px 12px; border-radius: 6px; transition: all 0.2s; }
        .nav-links .nav-link:hover { color: var(--white) !important; background: rgba(255,255,255,0.1); }
        .search-wrap { flex: 1; max-width: 720px; display: flex; }
        .search-wrap input { border: none; border-radius: 8px 0 0 8px; padding: 10px 16px; font-size: 0.9rem; outline: none; width: 100%; background: rgba(255,255,255,0.12); color: var(--white); }
        .search-wrap input::placeholder { color: rgba(255,255,255,0.5); }
        .search-wrap input:focus { background: rgba(255,255,255,0.2); }
        .search-wrap button { background: var(--purple-light); border: none; border-radius: 0 8px 8px 0; padding: 10px 16px; color: var(--white); cursor: pointer; }
        .search-wrap button:hover { background: var(--accent); }
        .nav-right { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0; padding: 0; }
        .user-chip { background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.4); color: var(--white) !important; border-radius: 20px; padding: 5px 14px; font-size: 0.85rem; font-weight: 600; }
        .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8) !important; border-radius: 8px; padding: 5px 12px; font-size: 0.83rem; text-decoration: none; }
        .btn-login { background: var(--white); color: var(--purple-deep) !important; border: none; border-radius: 8px; padding: 7px 16px; font-size: 0.88rem; font-weight: 700; text-decoration: none; }
        .btn-cart { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: var(--white) !important; border-radius: 8px; padding: 7px 14px; font-size: 0.88rem; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 6px; }
        .btn-cart .badge { background: var(--purple-light) !important; color: var(--white) !important; border-radius: 50px; font-size: 0.75rem; }
        .btn-seller { background: var(--accent); color: var(--white) !important; border: none; border-radius: 8px; padding: 7px 14px; font-size: 0.85rem; font-weight: 600; text-decoration: none; }
        .btn-add-product { background: #16a34a; color: var(--white) !important; border: none; border-radius: 8px; padding: 7px 14px; font-size: 0.85rem; font-weight: 600; text-decoration: none; }

        /* ── LAYOUT ── */
        .page-wrap { display: grid; grid-template-columns: 220px 1fr; gap: 24px; max-width: 1400px; margin: 28px auto; padding: 0 20px; }

        /* ── SIDEBAR ── */
        .sidebar { background: var(--white); border-radius: 14px; box-shadow: 0 2px 12px rgba(109,40,217,0.07); padding: 20px 16px; height: fit-content; position: sticky; top: 80px; }
        .sidebar h5 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--purple-mid); margin-bottom: 14px; padding-bottom: 10px; border-bottom: 2px solid var(--purple-pale); }
        .cat-btn { display: flex; align-items: center; gap: 10px; width: 100%; padding: 9px 12px; margin-bottom: 4px; background: transparent; border: none; border-radius: 8px; color: var(--black); font-size: 0.9rem; font-weight: 500; text-decoration: none; transition: all 0.18s; }
        .cat-btn:hover, .cat-btn.active { background: var(--purple-pale); color: var(--purple-deep); text-decoration: none; }
        .cat-btn.active { background: var(--purple-deep); color: var(--white); font-weight: 600; }
        .cat-btn .cat-icon { font-size: 1.05rem; width: 20px; text-align: center; flex-shrink: 0; color: var(--purple-mid); }
        .cat-btn.active .cat-icon { color: var(--white); }

        /* ── CONTENT HEADER ── */
        .content-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; flex-wrap: wrap; gap: 12px; }
        .content-header h2 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.4rem; color: var(--black); margin: 0; }
        .sort-group { display: flex; gap: 6px; align-items: center; }
        .sort-group span { font-size: 0.82rem; color: var(--gray-500); }
        .sort-btn { background: var(--white); border: 1.5px solid var(--gray-200); color: var(--gray-500); border-radius: 8px; padding: 6px 14px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.18s; font-family: 'DM Sans', sans-serif; }
        .sort-btn:hover, .sort-btn.active { background: var(--purple-pale); border-color: var(--purple-mid); color: var(--purple-mid); }

        /* ── PRODUCT CARDS ── */
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
        .product-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); overflow: hidden; transition: all 0.22s; display: flex; flex-direction: column; }
        .product-card:hover { border-color: var(--purple-light); box-shadow: 0 8px 28px rgba(109,40,217,0.13); transform: translateY(-4px); }
        .product-card img { height: 170px; width: 100%; object-fit: cover; }
        .product-card-body { padding: 14px 16px 16px; display: flex; flex-direction: column; flex: 1; }
        .product-name { font-weight: 600; font-size: 0.92rem; color: var(--black); margin-bottom: 4px; line-height: 1.3; }
        .product-price { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.05rem; color: var(--purple-mid); margin-bottom: 12px; }
        .product-actions { display: flex; gap: 8px; margin-top: auto; }
        .btn-view { flex: 1; background: transparent; border: 1.5px solid var(--purple-mid); color: var(--purple-mid); border-radius: 8px; padding: 7px 0; font-size: 0.82rem; font-weight: 600; text-align: center; text-decoration: none; transition: all 0.18s; }
        .btn-view:hover { background: var(--purple-pale); color: var(--purple-deep); text-decoration: none; }
        .btn-addcart { flex: 1; background: var(--purple-deep); border: none; color: var(--white); border-radius: 8px; padding: 7px 0; font-size: 0.82rem; font-weight: 600; text-align: center; text-decoration: none; cursor: pointer; transition: all 0.18s; font-family: 'DM Sans', sans-serif; }
        .btn-addcart:hover { background: var(--purple-mid); }

        /* ── EMPTY STATE ── */
        .empty-state { text-align: center; padding: 80px 20px; background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); }
        .empty-state i { font-size: 3rem; color: var(--gray-200); margin-bottom: 16px; display: block; }
        .empty-state h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--black); margin-bottom: 6px; }
        .empty-state p { color: var(--gray-500); font-size: 0.88rem; }

        /* ── FOOTER ── */
        footer { background: var(--purple-deep); color: rgba(255,255,255,0.6); text-align: center; padding: 24px; font-size: 0.85rem; margin-top: 48px; }
        footer strong { color: var(--purple-light); }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <ul class="nav-links">
            <li><a class="nav-link" href="#">Store Locator</a></li>
        </ul>
        <form class="search-wrap" action="/search" method="GET">
            <input type="search" name="q" placeholder="Search products, brands, categories...">
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
        <ul class="nav-right">
            <li><a class="nav-link" href="#">Help</a></li>
            <li>
                <% if (user) { %>
                    <span class="user-chip"><%= user.username %></span>
                    <a href="/logout" class="btn-logout ms-2">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-login">Login / Signup</a>
                <% } %>
            </li>
            <li>
                <a class="btn-cart" href="/cart">
                    <i class="bi bi-bag"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                </a>
            </li>
            <% if (user && user.role === 'user') { %>
                <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
            <% } %>
            <% if (user && user.role === 'seller') { %>
                <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
            <% } %>
        </ul>
    </div>
</nav>

<div class="page-wrap">


    <aside>
        <div class="sidebar">
            <h5>Categories</h5>
            <a href="/category/all"         class="cat-btn <%= currentCategory === 'all' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-grid-fill"></i></span> All Categories</a>
            <a href="/category/computers"   class="cat-btn <%= currentCategory === 'computers' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-laptop"></i></span> Computers &amp; Accessories</a>
            <a href="/category/phones"      class="cat-btn <%= currentCategory === 'phones' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-phone"></i></span> Phones &amp; Tablets</a>
            <a href="/category/electronics" class="cat-btn <%= currentCategory === 'electronics' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-lightning-charge"></i></span> Electronics</a>
            <a href="/category/fashion"     class="cat-btn <%= currentCategory === 'fashion' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-bag"></i></span> Fashion</a>
            <a href="/category/home"        class="cat-btn <%= currentCategory === 'home' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-house"></i></span> Home &amp; Kitchen</a>
            <a href="/category/kids"        class="cat-btn <%= currentCategory === 'kids' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-star"></i></span> Kids &amp; Toys</a>
            <a href="/category/beauty"      class="cat-btn <%= currentCategory === 'beauty' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-heart"></i></span> Beauty &amp; Health</a>
        </div>
    </aside>


    <main>
        <div class="content-header">
            <h2><%= currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1) %></h2>
            <div class="sort-group">
                <span>Sort by:</span>
                <button class="sort-btn <%= currentSort === 'relevance' ? 'active' : '' %>"
                    onclick="location.href='/category/<%= currentCategory %>'">Relevance</button>
                <button class="sort-btn <%= currentSort === 'high' ? 'active' : '' %>"
                    onclick="location.href='/category/<%= currentCategory %>?sort=high'">Price: High to Low</button>
                <button class="sort-btn <%= currentSort === 'low' ? 'active' : '' %>"
                    onclick="location.href='/category/<%= currentCategory %>?sort=low'">Price: Low to High</button>
            </div>
        </div>

        <% if (products.length === 0) { %>
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <h3>No products found</h3>
                <p>There are no products in this category yet.</p>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% products.forEach(function(product) { %>
                    <div class="product-card">
                        <img src="<%= product.image && product.image !== '' ? product.image : '/images/pc.jpg' %>" alt="<%= product.name %>">
                        <div class="product-card-body">
                            <div class="product-name"><%= product.name %></div>
                            <div class="product-price">₦<%= product.price.toLocaleString() %></div>
                            <div class="product-actions">
                                <a href="/product/<%= product.id %>" class="btn-view">View</a>
                                <form method="POST" action="/cart/add" style="flex:1;display:flex;">
                                    <input type="hidden" name="product_id" value="<%= product.id %>">
                                    <input type="hidden" name="quantity" value="1">
                                    <button type="submit" class="btn-addcart" style="width:100%">Add to Cart</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
