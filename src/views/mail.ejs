<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PwnMail - Pwnshop Inbox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }
        * { box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--gray-100); color: var(--black); margin: 0; }

        /* ── NAVBAR ── */
        .topbar { background: var(--purple-deep); padding: 0; position: sticky; top: 0; z-index: 1000; box-shadow: 0 2px 16px rgba(59,7,100,0.4); }
        .topbar .container { display: flex; align-items: center; gap: 16px; padding: 12px 24px; }
        .navbar-brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--white) !important; text-decoration: none; display: flex; align-items: center; gap: 6px; }
        .navbar-brand .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .nav-right { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0 0 0 auto; padding: 0; }
        .user-chip { text-decoration: none; background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.4); color: var(--white) !important; border-radius: 20px; padding: 5px 14px; font-size: 0.85rem; font-weight: 600; }
        .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8) !important; border-radius: 8px; padding: 5px 12px; font-size: 0.83rem; text-decoration: none; }
        .btn-logout:hover { border-color: #f87171; color: #f87171 !important; }
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        /* ── PAGE ── */
        .page-wrap { max-width: 860px; margin: 36px auto; padding: 0 20px 60px; }

        /* ── MAIL HEADER ── */
        .mail-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            gap: 12px;
            flex-wrap: wrap;
        }
        .mail-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .mail-icon-wrap {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, var(--purple-deep), var(--purple-mid));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-size: 1.1rem;
        }
        .mail-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.3rem; color: var(--black); }
        .mail-subtitle { font-size: 0.78rem; color: var(--gray-500); margin-top: 1px; }
        .unread-badge {
            background: var(--purple-mid);
            color: var(--white);
            font-size: 0.72rem;
            font-weight: 700;
            border-radius: 20px;
            padding: 3px 10px;
        }

        /* Viewing someone else's inbox */
        .viewing-notice {
            background: var(--purple-pale);
            border: 1.5px solid rgba(109,40,217,0.2);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.84rem;
            color: var(--purple-mid);
        }
        .viewing-notice i { font-size: 1rem; flex-shrink: 0; }
        .viewing-notice strong { color: var(--purple-deep); }

        /* ── EMPTY STATE ── */
        .mail-empty {
            text-align: center;
            padding: 80px 20px;
            background: var(--white);
            border-radius: 16px;
            border: 1.5px solid var(--gray-200);
        }
        .mail-empty i { font-size: 3rem; color: var(--gray-200); display: block; margin-bottom: 14px; }
        .mail-empty h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--black); margin-bottom: 6px; }
        .mail-empty p { color: var(--gray-500); font-size: 0.85rem; }

        /* ── MAIL LIST ── */
        .mail-list { display: flex; flex-direction: column; gap: 0; background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); overflow: hidden; }

        .mail-row {
            display: grid;
            grid-template-columns: 16px 1fr auto;
            gap: 14px;
            align-items: start;
            padding: 16px 20px;
            border-bottom: 1px solid var(--gray-200);
            cursor: pointer;
            transition: background 0.15s;
            position: relative;
        }
        .mail-row:last-child { border-bottom: none; }
        .mail-row:hover { background: var(--gray-100); }
        .mail-row.unread { background: var(--white); }
        .mail-row.read   { background: var(--gray-100); }

        .unread-dot {
            width: 8px;
            height: 8px;
            background: var(--purple-mid);
            border-radius: 50%;
            margin-top: 6px;
            flex-shrink: 0;
        }
        .read-dot {
            width: 8px;
            height: 8px;
            flex-shrink: 0;
        }

        .mail-content { min-width: 0; }
        .mail-from   { font-size: 0.72rem; color: var(--gray-500); margin-bottom: 2px; }
        .mail-subject {
            font-weight: 700;
            font-size: 0.92rem;
            color: var(--black);
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .mail-row.read .mail-subject { font-weight: 500; color: var(--gray-500); }
        .mail-preview {
            font-size: 0.8rem;
            color: var(--gray-500);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .mail-time {
            font-size: 0.75rem;
            color: var(--gray-500);
            white-space: nowrap;
            padding-top: 4px;
        }

        /* ── EXPANDED MAIL BODY ── */
        .mail-body-wrap {
            display: none;
            grid-column: 1 / -1;
            padding: 0 0 4px 22px;
            margin-top: 8px;
        }
        .mail-body-wrap.open { display: block; }

        .mail-body-inner {
            background: var(--gray-100);
            border-radius: 10px;
            padding: 16px 18px;
            font-size: 0.85rem;
            color: var(--black);
            line-height: 1.7;
            white-space: pre-wrap;
            word-break: break-word;
            border: 1.5px solid var(--gray-200);
        }

        /* ── FOOTER ── */
        footer { background: var(--purple-deep); color: rgba(255,255,255,0.6); text-align: center; padding: 24px; font-size: 0.85rem; margin-top: 48px; }
        footer strong { color: var(--purple-light); }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <ul class="nav-right">
            <li><a class="nav-link-plain" href="/">Home</a></li>
            <li><a class="nav-link-plain" href="/profile">Profile</a></li>
            <% if (user) { %>
                <li><a href="/profile" class="user-chip"><%= user.username %></a></li>
                <li><a href="/logout" class="btn-logout">Logout</a></li>
            <% } else { %>
                <li><a href="/login" class="nav-link-plain">Login</a></li>
            <% } %>
        </ul>
    </div>
</nav>

<div class="page-wrap">


    <div class="mail-header">
        <div class="mail-brand">
            <div class="mail-icon-wrap"><i class="bi bi-envelope-fill"></i></div>
            <div>
                <div class="mail-title">PwnMail</div>
                <div class="mail-subtitle">
                    <% if (mailOwner) { %>
                        Inbox · <%= mailOwner.username %> &lt;<%= mailOwner.email %>&gt;
                    <% } else { %>
                        Inbox · User #<%= userId %>
                    <% } %>
                </div>
            </div>
        </div>
        <% if (unread > 0) { %>
            <span class="unread-badge"><%= unread %> unread</span>
        <% } %>
    </div>


    <% if (user && mailOwner && user.id !== mailOwner.id) { %>
        <div class="viewing-notice">
            <i class="bi bi-eye"></i>
            <span>Viewing inbox of <strong><%= mailOwner.username %></strong> — <a href="/mail/<%= user.id %>" style="color:var(--purple-mid);font-weight:600;text-decoration:none;">Switch to your inbox</a></span>
        </div>
    <% } %>
    <% if (!user) { %>
        <div class="viewing-notice">
            <i class="bi bi-eye"></i>
            <span>You are viewing this inbox as a guest. <a href="/login" style="color:var(--purple-mid);font-weight:600;text-decoration:none;">Sign in</a></span>
        </div>
    <% } %>


    <% if (mails.length === 0) { %>
        <div class="mail-empty">
            <i class="bi bi-inbox"></i>
            <h3>No messages yet</h3>
            <p>Messages sent to this account will appear here.</p>
        </div>
    <% } else { %>
        <div class="mail-list">
            <% mails.forEach((mail, idx) => { %>
                <div class="mail-row <%= mail.is_read ? 'read' : 'unread' %>" id="row-<%= mail.id %>" onclick="toggleMail(<%= mail.id %>, this)">
                    <% if (!mail.is_read) { %>
                        <div class="unread-dot"></div>
                    <% } else { %>
                        <div class="read-dot"></div>
                    <% } %>

                    <div class="mail-content">
                        <div class="mail-from"><%= mail.from_name || 'Pwnshop' %></div>
                        <div class="mail-subject"><%= mail.subject %></div>
                        <div class="mail-preview"><%= mail.body.replace(/\n/g, ' ').substring(0, 90) %>…</div>


                        <div class="mail-body-wrap" id="body-<%= mail.id %>">
                            <div class="mail-body-inner"><%= mail.body %></div>
                        </div>
                    </div>

                    <div class="mail-time">
                        <%= new Date(mail.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %>
                        <br>
                        <span style="color:var(--gray-500);font-size:0.7rem;">
                            <%= new Date(mail.created_at).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %>
                        </span>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>

</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script>
function toggleMail(id, row) {
    const body = document.getElementById('body-' + id);
    const isOpen = body.classList.contains('open');


    document.querySelectorAll('.mail-body-wrap.open').forEach(el => el.classList.remove('open'));

    if (!isOpen) {
        body.classList.add('open');


        if (row.classList.contains('unread')) {
            row.classList.remove('unread');
            row.classList.add('read');
            const dot = row.querySelector('.unread-dot');
            if (dot) { dot.className = 'read-dot'; }

            fetch('/mail/' + id + '/read', { method: 'POST' });


            const badge = document.querySelector('.unread-badge');
            if (badge) {
                const current = parseInt(badge.textContent);
                if (current <= 1) { badge.remove(); }
                else { badge.textContent = (current - 1) + ' unread'; }
            }
        }
    }
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
