<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice — Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root{--purple-deep:#3B0764;--purple-mid:#6D28D9;--purple-light:#A855F7;--purple-pale:#F3E8FF;--black:#0D0D0D;--white:#FFFFFF;--gray-100:#F8F5FF;--gray-200:#EDE9F6;--gray-500:#6B7280;}
        *{box-sizing:border-box;margin:0;padding:0;}
        body{font-family:"DM Sans",sans-serif;background:var(--gray-100);color:var(--black);min-height:100vh;}
        .topbar{background:var(--purple-deep);padding:0;position:sticky;top:0;z-index:1000;box-shadow:0 2px 16px rgba(59,7,100,0.4);}
        .topbar .container{display:flex;align-items:center;gap:16px;padding:12px 24px;}
        .navbar-brand{font-family:"Syne",sans-serif;font-weight:800;font-size:1.6rem;color:var(--white)!important;text-decoration:none;display:flex;align-items:center;gap:6px;}
        .navbar-brand .dot{width:8px;height:8px;background:var(--purple-light);border-radius:50%;}
        .nav-right{display:flex;align-items:center;gap:8px;list-style:none;margin:0 0 0 auto;padding:0;}
        .user-chip{text-decoration:none;background:rgba(168,85,247,0.2);border:1px solid rgba(168,85,247,0.4);color:var(--white)!important;border-radius:20px;padding:5px 14px;font-size:0.85rem;font-weight:600;}
        .btn-logout{background:transparent;border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.8)!important;border-radius:8px;padding:5px 12px;font-size:0.83rem;text-decoration:none;}
        .nav-link-plain{color:rgba(255,255,255,0.75)!important;font-size:0.88rem;padding:6px 12px;border-radius:6px;text-decoration:none;}
        .nav-link-plain:hover{background:rgba(255,255,255,0.1);color:var(--white)!important;}
        .page-wrap{max-width:760px;margin:36px auto;padding:0 20px 60px;}
        .invoice-card{background:var(--white);border-radius:16px;border:1.5px solid var(--gray-200);overflow:hidden;box-shadow:0 4px 24px rgba(59,7,100,0.08);}
        .invoice-header{background:linear-gradient(135deg,var(--purple-deep),var(--purple-mid));padding:28px 32px;display:flex;align-items:center;justify-content:space-between;}
        .invoice-header .brand{font-family:"Syne",sans-serif;font-weight:800;font-size:1.5rem;color:var(--white);display:flex;align-items:center;gap:6px;}
        .invoice-header .brand .dot{width:7px;height:7px;background:var(--purple-light);border-radius:50%;}
        .invoice-header .inv-meta{text-align:right;}
        .invoice-header .inv-num{font-family:"Syne",sans-serif;font-weight:800;font-size:1rem;color:var(--white);}
        .invoice-header .inv-date{font-size:0.75rem;color:rgba(255,255,255,0.6);margin-top:4px;}
        .invoice-body{padding:28px 32px;}
        .invoice-meta{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:28px;padding-bottom:24px;border-bottom:1.5px solid var(--gray-200);}
        .meta-block .meta-label{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:var(--gray-500);margin-bottom:6px;}
        .meta-block .meta-value{font-size:0.88rem;color:var(--black);line-height:1.6;}
        .meta-block .meta-value strong{display:block;font-size:0.9rem;margin-bottom:2px;}
        .status-pill{display:inline-flex;align-items:center;gap:5px;font-size:0.72rem;font-weight:700;border-radius:20px;padding:4px 12px;text-transform:uppercase;}
        .s-pending{background:#fffbeb;color:#92400e;} .s-processing{background:#eff6ff;color:#1d4ed8;}
        .s-shipped{background:#ecfeff;color:#0e7490;} .s-delivered{background:#f0fdf4;color:#15803d;}
        .s-cancelled{background:#fef2f2;color:#dc2626;}
        .items-table{width:100%;border-collapse:collapse;margin-bottom:24px;}
        .items-table th{padding:10px 14px;text-align:left;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--gray-500);background:var(--gray-100);border-bottom:1.5px solid var(--gray-200);}
        .items-table th:last-child,.items-table td:last-child{text-align:right;}
        .items-table td{padding:13px 14px;font-size:0.86rem;border-bottom:1px solid var(--gray-200);color:var(--black);vertical-align:middle;}
        .items-table td:last-child{font-family:"Syne",sans-serif;font-weight:700;color:var(--purple-mid);}
        .items-table tr:last-child td{border-bottom:none;}
        .totals-block{margin-left:auto;width:260px;}
        .total-line{display:flex;justify-content:space-between;align-items:center;padding:7px 0;font-size:0.85rem;color:var(--gray-500);border-bottom:1px solid var(--gray-200);}
        .total-line:last-child{border-bottom:none;}
        .total-line.grand{padding:12px 0 4px;font-family:"Syne",sans-serif;font-weight:800;font-size:1rem;color:var(--black);border-top:2px solid var(--gray-200);border-bottom:none;margin-top:4px;}
        .total-line.grand span:last-child{color:var(--purple-mid);font-size:1.1rem;}
        .total-line.discount{color:#16a34a;font-weight:600;}
        .file-output-card{background:var(--gray-100);border:1.5px solid var(--gray-200);border-radius:10px;padding:20px 24px;font-family:"JetBrains Mono",monospace;font-size:0.8rem;line-height:1.75;color:var(--black);white-space:pre-wrap;word-break:break-word;max-height:480px;overflow-y:auto;}
        .not-found-state{text-align:center;padding:48px 20px;}
        .not-found-state i{font-size:2.5rem;color:var(--gray-200);display:block;margin-bottom:12px;}
        .not-found-state h3{font-family:"Syne",sans-serif;font-weight:700;font-size:1rem;color:var(--black);margin-bottom:6px;}
        .not-found-state p{color:var(--gray-500);font-size:0.85rem;}
        .action-row{display:flex;gap:12px;margin-top:22px;}
        .btn-primary-purple{background:var(--purple-deep);color:var(--white);border:none;border-radius:10px;padding:11px 22px;font-size:0.88rem;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:background 0.2s;font-family:"DM Sans",sans-serif;cursor:pointer;}
        .btn-primary-purple:hover{background:var(--purple-mid);color:var(--white);}
        .btn-outline-gray{background:transparent;color:var(--gray-500);border:1.5px solid var(--gray-200);border-radius:10px;padding:10px 22px;font-size:0.88rem;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all 0.2s;font-family:"DM Sans",sans-serif;cursor:pointer;}
        .btn-outline-gray:hover{border-color:var(--purple-mid);color:var(--purple-mid);}
        footer{background:var(--purple-deep);color:rgba(255,255,255,0.6);text-align:center;padding:24px;font-size:0.85rem;margin-top:48px;}
        footer strong{color:var(--purple-light);}
        @media print{.topbar,.action-row,footer{display:none;}body{background:var(--white);}.page-wrap{margin:0;padding:0;max-width:100%;}.invoice-card{box-shadow:none;border:none;}}
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>
<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <ul class="nav-right">
            <li><a class="nav-link-plain" href="/">Home</a></li>
            <li><a class="nav-link-plain" href="/profile">My Orders</a></li>
            <% if (user) { %>
                <li><a href="/profile" class="user-chip"><%= user.username %></a></li>
                <li><a href="/logout" class="btn-logout">Logout</a></li>
            <% } %>
        </ul>
    </div>
</nav>
<div class="page-wrap">
    <div class="invoice-card">
        <div class="invoice-header">
            <div class="brand">Pwnshop<span class="dot"></span></div>
            <div class="inv-meta">
                <% if (order) { %>
                    <div class="inv-num">Invoice #INV-<%= String(order.id).padStart(4,'0') %></div>
                    <div class="inv-date"><%= new Date(order.created_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></div>
                <% } else { %>
                    <div class="inv-num">Invoice #INV-<%= String(orderId).replace(/[^0-9]/g,'').padStart(4,'0') || '----' %></div>
                    <div class="inv-date"><%= new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></div>
                <% } %>
            </div>
        </div>
        <div class="invoice-body">
            <% if (order) { %>
                <div class="invoice-meta">
                    <div class="meta-block">
                        <div class="meta-label">Billed To</div>
                        <div class="meta-value">
                            <strong><%= order.username %></strong>
                            <%= order.email %><br>
                            <% if (order.phone) { %><%= order.phone %><br><% } %>
                            <%= order.shipping_address %>
                        </div>
                    </div>
                    <div class="meta-block">
                        <div class="meta-label">Order Details</div>
                        <div class="meta-value">
                            <strong>Order #<%= order.id %></strong>
                            Placed: <%= new Date(order.created_at).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) %><br>
                            Status: <span class="status-pill s-<%= order.status %>"><%= order.status.toUpperCase() %></span>
                            <% if (order.coupon_code) { %><br>Coupon: <code style="font-size:0.78rem;background:var(--purple-pale);color:var(--purple-mid);padding:1px 6px;border-radius:4px;"><%= order.coupon_code %></code><% } %>
                        </div>
                    </div>
                </div>
                <table class="items-table">
                    <thead>
                        <tr><th>Item</th><th style="text-align:center;">Qty</th><th style="text-align:right;">Unit Price</th><th>Total</th></tr>
                    </thead>
                    <tbody>
                        <% items.forEach(item => { %>
                        <tr>
                            <td><%= item.name %></td>
                            <td style="text-align:center;"><%= item.quantity %></td>
                            <td style="text-align:right;font-family:'Syne',sans-serif;font-weight:600;color:var(--black);">&#8358;<%= parseFloat(item.price).toLocaleString('en-NG',{minimumFractionDigits:2}) %></td>
                            <td>&#8358;<%= (parseFloat(item.price)*item.quantity).toLocaleString('en-NG',{minimumFractionDigits:2}) %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <%
                    const subtotal = items.reduce((s,i)=>s+parseFloat(i.price)*i.quantity,0);
                    const discount = parseFloat(order.discount_amount||0);
                    const total    = parseFloat(order.total_amount);
                %>
                <div class="totals-block">
                    <div class="total-line"><span>Subtotal</span><span>&#8358;<%= subtotal.toLocaleString('en-NG',{minimumFractionDigits:2}) %></span></div>
                    <% if (discount > 0) { %>
                    <div class="total-line discount"><span>Discount</span><span>&#8722;&#8358;<%= discount.toLocaleString('en-NG',{minimumFractionDigits:2}) %></span></div>
                    <% } %>
                    <div class="total-line"><span>Shipping</span><span style="color:#16a34a;font-weight:600;">FREE</span></div>
                    <div class="total-line grand"><span>Total Paid</span><span>&#8358;<%= total.toLocaleString('en-NG',{minimumFractionDigits:2}) %></span></div>
                </div>
            <% } else if (fileContent !== null) { %>
                <div class="file-output-card"><%= fileContent %></div>
            <% } else { %>
                <div class="not-found-state">
                    <i class="bi bi-file-earmark-x"></i>
                    <h3>Invoice not found</h3>
                    <p>No order matching <strong>#<%= orderId %></strong> could be located.</p>
                </div>
            <% } %>
        </div>
    </div>
    <div class="action-row">
        <a href="/profile" class="btn-primary-purple"><i class="bi bi-arrow-left"></i> Back to Orders</a>
        <button onclick="window.print()" class="btn-outline-gray"><i class="bi bi-printer"></i> Print Invoice</button>
    </div>
</div>
<footer>&copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
