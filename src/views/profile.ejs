<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }
        * { box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--gray-100); color: var(--black); margin: 0; }
        .topbar { background: var(--purple-deep); padding: 0; position: sticky; top: 0; z-index: 1000; box-shadow: 0 2px 16px rgba(59,7,100,0.4); }
        .topbar .container { display: flex; align-items: center; gap: 16px; padding: 12px 24px; }
        .navbar-brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--white) !important; text-decoration: none; display: flex; align-items: center; gap: 6px; }
        .navbar-brand .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .nav-right { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0 0 0 auto; padding: 0; }
        .user-chip { text-decoration: none; background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.4); color: var(--white) !important; border-radius: 20px; padding: 5px 14px; font-size: 0.85rem; font-weight: 600; }
        .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8) !important; border-radius: 8px; padding: 5px 12px; font-size: 0.83rem; text-decoration: none; }
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }
        .btn-cart { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: var(--white) !important; border-radius: 8px; padding: 7px 14px; font-size: 0.88rem; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 6px; }
        .btn-cart .badge { background: var(--purple-light) !important; color: var(--white) !important; border-radius: 50px; font-size: 0.75rem; }
        .page-wrap { max-width: 1100px; margin: 36px auto; padding: 0 20px 60px; display: grid; grid-template-columns: 300px 1fr; gap: 24px; align-items: start; }
        .profile-card { background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); overflow: hidden; position: sticky; top: 90px; }
        .profile-hero { background: linear-gradient(145deg, var(--purple-deep), var(--purple-mid)); padding: 28px 24px; text-align: center; }
        .avatar-wrap { position: relative; width: 72px; height: 72px; margin: 0 auto 12px; }
        .avatar { width: 72px; height: 72px; background: rgba(255,255,255,0.18); border: 3px solid rgba(255,255,255,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.8rem; color: var(--white); overflow: hidden; }
        .avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
        .profile-name { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem; color: var(--white); margin-bottom: 4px; }
        .profile-role-badge { display: inline-block; background: rgba(255,255,255,0.15); color: var(--white); font-size: 0.72rem; font-weight: 700; border-radius: 20px; padding: 3px 12px; letter-spacing: 0.4px; text-transform: uppercase; }
        .wallet-strip { margin: 20px 16px; background: linear-gradient(135deg, var(--purple-deep), var(--accent)); border-radius: 12px; padding: 16px 18px; }
        .wallet-strip .wl { font-size: 0.72rem; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
        .wallet-strip .wa { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.5rem; color: var(--white); }
        .profile-info { padding: 0 16px 16px; }
        .info-row { padding: 12px 0; border-bottom: 1px solid var(--gray-200); }
        .info-row:last-child { border-bottom: none; }
        .info-label { font-size: 0.72rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 2px; }
        .info-value { font-size: 0.88rem; color: var(--black); font-weight: 500; }

        /* Avatar URL field */
        .avatar-section { padding: 16px; border-top: 1.5px solid var(--gray-200); }
        .avatar-section h5 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.75rem; color: var(--black); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.3px; }
        .avatar-url-wrap { display: flex; gap: 6px; }
        .avatar-url-input { flex: 1; border: 1.5px solid var(--gray-200); border-radius: 8px; padding: 8px 10px; font-size: 0.78rem; font-family: 'DM Sans', sans-serif; outline: none; color: var(--black); transition: border-color 0.2s; min-width: 0; }
        .avatar-url-input:focus { border-color: var(--purple-mid); }
        .avatar-url-input::placeholder { color: #b0afc0; }
        .btn-set-avatar { background: var(--purple-deep); color: var(--white); border: none; border-radius: 8px; padding: 8px 12px; font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: background 0.2s; white-space: nowrap; }
        .btn-set-avatar:hover { background: var(--purple-mid); }
        .avatar-result { margin-top: 8px; font-size: 0.72rem; display: none; border-radius: 6px; padding: 6px 10px; }
        .avatar-result.ok  { background: #f0fdf4; color: #15803d; }
        .avatar-result.err { background: #fef2f2; color: #dc2626; }

        .profile-actions { padding: 16px; display: flex; flex-direction: column; gap: 8px; border-top: 1.5px solid var(--gray-200); }
        .btn-action { display: flex; align-items: center; justify-content: center; gap: 7px; border-radius: 10px; padding: 10px; font-size: 0.85rem; font-weight: 700; text-decoration: none; transition: all 0.2s; font-family: 'DM Sans', sans-serif; border: none; cursor: pointer; }
        .btn-action-primary { background: var(--purple-deep); color: var(--white); }
        .btn-action-primary:hover { background: var(--purple-mid); color: var(--white); }
        .btn-action-outline { background: transparent; color: var(--purple-mid); border: 1.5px solid var(--purple-mid); }
        .btn-action-outline:hover { background: var(--purple-pale); color: var(--purple-deep); }
        .btn-action-danger { background: transparent; color: #dc2626; border: 1.5px solid #fecaca; }
        .btn-action-danger:hover { background: #fef2f2; }

        .tab-bar { display: flex; gap: 4px; margin-bottom: 20px; background: var(--white); border-radius: 12px; border: 1.5px solid var(--gray-200); padding: 4px; }
        .tab-btn { flex: 1; border: none; background: transparent; border-radius: 9px; padding: 9px 12px; font-size: 0.85rem; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; color: var(--gray-500); transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 7px; }
        .tab-btn.active { background: var(--purple-deep); color: var(--white); }
        .tab-btn .tab-count { font-size: 0.72rem; background: rgba(255,255,255,0.2); border-radius: 20px; padding: 1px 7px; }
        .tab-btn:not(.active) .tab-count { background: var(--purple-pale); color: var(--purple-mid); }
        .wishlist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
        .wl-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); overflow: hidden; transition: all 0.22s; }
        .wl-card:hover { border-color: var(--purple-light); box-shadow: 0 6px 20px rgba(109,40,217,0.1); transform: translateY(-3px); }
        .wl-card img { width: 100%; height: 130px; object-fit: cover; display: block; }
        .wl-card-placeholder { width: 100%; height: 130px; background: var(--gray-100); display: flex; align-items: center; justify-content: center; color: var(--gray-200); font-size: 2rem; }
        .wl-card-body { padding: 12px 14px; }
        .wl-name { font-weight: 600; font-size: 0.85rem; color: var(--black); margin-bottom: 3px; line-height: 1.3; }
        .wl-price { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.92rem; color: var(--purple-mid); margin-bottom: 10px; }
        .wl-actions { display: flex; gap: 6px; }
        .btn-wl-view { flex: 1; background: var(--purple-pale); color: var(--purple-mid); border: none; border-radius: 7px; padding: 6px 0; font-size: 0.78rem; font-weight: 700; text-align: center; text-decoration: none; font-family: 'DM Sans', sans-serif; transition: all 0.18s; display: flex; align-items: center; justify-content: center; }
        .btn-wl-view:hover { background: var(--purple-deep); color: var(--white); }
        .btn-wl-remove { background: var(--white); color: var(--gray-500); border: 1.5px solid var(--gray-200); border-radius: 7px; padding: 6px 8px; font-size: 0.78rem; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.18s; }
        .btn-wl-remove:hover { border-color: #fecaca; color: #dc2626; background: #fef2f2; }
        .order-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); padding: 18px 20px; margin-bottom: 14px; transition: all 0.22s; }
        .order-card:hover { border-color: var(--purple-light); box-shadow: 0 4px 20px rgba(109,40,217,0.1); }
        .order-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .order-num { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.95rem; color: var(--black); }
        .status-badge { display: inline-flex; align-items: center; gap: 5px; font-size: 0.72rem; font-weight: 700; border-radius: 20px; padding: 4px 12px; text-transform: uppercase; letter-spacing: 0.3px; }
        .status-pending    { background: #fffbeb; color: #92400e; }
        .status-processing { background: #eff6ff; color: #1d4ed8; }
        .status-shipped    { background: #ecfeff; color: #0e7490; }
        .status-delivered  { background: #f0fdf4; color: #15803d; }
        .order-meta { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
        .order-meta-item { display: flex; align-items: center; gap: 5px; font-size: 0.8rem; color: var(--gray-500); }
        .order-total { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--purple-mid); }
        .btn-view-order { display: inline-flex; align-items: center; gap: 5px; margin-top: 12px; background: var(--purple-pale); color: var(--purple-mid); border: none; border-radius: 8px; padding: 7px 16px; font-size: 0.82rem; font-weight: 700; text-decoration: none; transition: all 0.18s; font-family: 'DM Sans', sans-serif; }
        .btn-view-order:hover { background: var(--purple-deep); color: var(--white); }
        .empty-state { text-align: center; padding: 60px 20px; background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); }
        .empty-state i { font-size: 2.5rem; color: var(--gray-200); display: block; margin-bottom: 12px; }
        .empty-state h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--black); margin-bottom: 6px; }
        .empty-state p { color: var(--gray-500); font-size: 0.85rem; }
        .btn-browse { display: inline-flex; align-items: center; gap: 6px; margin-top: 18px; background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 10px 22px; font-size: 0.85rem; font-weight: 700; text-decoration: none; transition: background 0.2s; }
        .btn-browse:hover { background: var(--purple-mid); color: var(--white); }
        footer { background: var(--purple-deep); color: rgba(255,255,255,0.6); text-align: center; padding: 24px; font-size: 0.85rem; margin-top: 48px; }
        footer strong { color: var(--purple-light); }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <ul class="nav-right">
            <li><a class="nav-link-plain" href="/">Home</a></li>
            <li><a class="btn-cart" href="/cart"><i class="bi bi-bag"></i> My Cart <span class="badge ms-1"><%= cartCount %></span></a></li>
            <li><a href="/profile" class="user-chip"><%= user.username %></a></li>
            <li><a href="/logout" class="btn-logout">Logout</a></li>
        </ul>
    </div>
</nav>

<div class="page-wrap">


    <aside>
        <div class="profile-card">
            <div class="profile-hero">
                <div class="avatar-wrap">
                    <div class="avatar" id="avatarDisplay" title="Click to upload a new picture" style="cursor:pointer" onclick="document.getElementById('avatarFileInput').click()">
                        <% if (user.avatar_url) {
                               const isSvg = user.avatar_url.toLowerCase().endsWith('.svg'); %>
                            <% if (isSvg) { %>
                                <%# SVG rendered as <object> so its scripts/event-handlers execute (stored XSS) %>
                                <object data="<%= user.avatar_url %>" type="image/svg+xml"
                                        style="width:100%;height:100%;border-radius:50%;pointer-events:none;"
                                        onerror="this.style.display='none'"></object>
                            <% } else { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" onerror="this.style.display='none'">
                            <% } %>
                        <% } else { %>
                            <%= user.username.charAt(0).toUpperCase() %>
                        <% } %>
                    </div>
                    <%# Hidden file input — triggered by clicking the avatar %>
                    <input type="file" id="avatarFileInput" accept="image/*,.svg"
                           style="display:none" onchange="uploadAvatarFile(this)">
                </div>
                <div class="profile-name"><%= user.username %></div>
                <span class="profile-role-badge"><%= user.role %><% if (user.isSeller) { %> · Seller<% } %></span>
            </div>

            <div class="wallet-strip">
                <div class="wl">Wallet Balance</div>
                <div class="wa">₦<%= parseFloat(user.wallet_amount || 0).toFixed(2) %></div>
            </div>

            <div class="profile-info">
                <div class="info-row">
                    <div class="info-label">Email</div>
                    <div class="info-value"><%= user.email %></div>
                </div>
                <div class="info-row">
                    <div class="info-label">Phone</div>
                    <div class="info-value"><%= user.phone || 'Not provided' %></div>
                </div>
                <div class="info-row">
                    <div class="info-label">Member Since</div>
                    <div class="info-value"><%= new Date(user.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
                </div>
            </div>


            <div class="avatar-section">
                <h5><i class="bi bi-image"></i> Profile Picture</h5>
                <p style="font-size:0.72rem;color:var(--gray-500);margin:0 0 8px">
                    <i class="bi bi-upload"></i> Click your avatar to upload a file, or paste a URL below.
                </p>
                <div class="avatar-url-wrap">
                    <input type="text" class="avatar-url-input" id="avatarUrlInput"
                           placeholder="https://example.com/photo.jpg"
                           value="<%= user.avatar_url || '' %>">
                    <button class="btn-set-avatar" id="setAvatarBtn">Set</button>
                </div>
                <div class="avatar-result" id="avatarResult"></div>
            </div>

            <div class="profile-actions">
                <% if (!user.isSeller) { %>
                    <a href="/register-seller" class="btn-action btn-action-primary"><i class="bi bi-shop"></i> Become a Seller</a>
                <% } else { %>
                    <a href="/seller/dashboard" class="btn-action btn-action-primary"><i class="bi bi-graph-up"></i> Seller Dashboard</a>
                <% } %>
                <a href="/mail" class="btn-action btn-action-outline"><i class="bi bi-envelope"></i> My Inbox</a>
                <a href="/vulnerabilities" class="btn-action btn-action-outline"><i class="bi bi-bug"></i> Vulnerabilities</a>

                <form method="POST" action="/account/delete" id="deleteAccountForm">
                    <button type="button" class="btn-action btn-action-danger" style="width:100%"
                            onclick="if(confirm('Permanently delete your account? This cannot be undone.')) document.getElementById('deleteAccountForm').submit()">
                        <i class="bi bi-trash3"></i> Delete Account
                    </button>
                </form>
            </div>
        </div>
    </aside>


    <main>
        <div class="tab-bar">
            <button class="tab-btn active" id="tab-orders-btn" onclick="switchTab('orders')">
                <i class="bi bi-bag"></i> My Orders
                <span class="tab-count"><%= orders.length %></span>
            </button>
            <button class="tab-btn" id="tab-wishlist-btn" onclick="switchTab('wishlist')">
                <i class="bi bi-heart"></i> Wishlist
                <span class="tab-count"><%= wishlist.length %></span>
            </button>
        </div>


        <div id="panel-orders">
            <% if (orders.length === 0) { %>
                <div class="empty-state">
                    <i class="bi bi-bag-x"></i>
                    <h3>No orders yet</h3>
                    <p>Start shopping to see your orders here.</p>
                    <a href="/" class="btn-browse"><i class="bi bi-grid"></i> Browse Products</a>
                </div>
            <% } else { %>
                <% orders.forEach(order => { %>
                    <div class="order-card">
                        <div class="order-card-top">
                            <div class="order-num">Order #<%= order.id %></div>
                            <span class="status-badge status-<%= order.status %>">
                                <i class="bi bi-circle-fill" style="font-size:0.45rem"></i>
                                <%= order.status.toUpperCase() %>
                            </span>
                        </div>
                        <div class="order-meta">
                            <div class="order-meta-item">
                                <i class="bi bi-calendar3"></i>
                                <%= new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </div>
                            <div class="order-meta-item">
                                <i class="bi bi-geo-alt"></i>
                                <%= order.shipping_address.substring(0, 40) %><%= order.shipping_address.length > 40 ? '…' : '' %>
                            </div>
                            <div class="order-total">₦<%= parseFloat(order.total_amount).toFixed(2) %></div>
                        </div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;">
                            <a href="/order/<%= order.id %>" class="btn-view-order">
                                <i class="bi bi-eye"></i> View Details
                            </a>
                            <a href="/track/<%= order.id %>" class="btn-view-order" style="background:var(--gray-100);color:var(--gray-500);border:1.5px solid var(--gray-200);">
                                <i class="bi bi-geo-alt"></i> Track
                            </a>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>


        <div id="panel-wishlist" style="display:none">
            <% if (wishlist.length === 0) { %>
                <div class="empty-state">
                    <i class="bi bi-heart"></i>
                    <h3>Your wishlist is empty</h3>
                    <p>Save products you love and find them here.</p>
                    <a href="/" class="btn-browse"><i class="bi bi-grid"></i> Browse Products</a>
                </div>
            <% } else { %>
                <div class="wishlist-grid">
                    <% wishlist.forEach(item => { %>
                        <div class="wl-card">
                            <% if (item.image && item.image !== '') { %>
                                <img src="<%= item.image %>" alt="<%= item.name %>">
                            <% } else { %>
                                <div class="wl-card-placeholder"><i class="bi bi-image"></i></div>
                            <% } %>
                            <div class="wl-card-body">
                                <div class="wl-name"><%= item.name %></div>
                                <div class="wl-price">₦<%= parseFloat(item.price).toLocaleString() %></div>
                                <div class="wl-actions">
                                    <a href="/product/<%= item.product_id %>" class="btn-wl-view">View</a>
                                    <form method="POST" action="/wishlist/remove" style="display:inline">
                                        <input type="hidden" name="product_id" value="<%= item.product_id %>">
                                        <input type="hidden" name="redirect_to" value="/profile">
                                        <button type="submit" class="btn-wl-remove"><i class="bi bi-trash3"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </main>

</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script>
function switchTab(tab) {
    document.getElementById('panel-orders').style.display   = tab === 'orders'   ? '' : 'none';
    document.getElementById('panel-wishlist').style.display = tab === 'wishlist' ? '' : 'none';
    document.getElementById('tab-orders-btn').classList.toggle('active',   tab === 'orders');
    document.getElementById('tab-wishlist-btn').classList.toggle('active', tab === 'wishlist');
}

function showAvatarResult(ok, msg) {
    var result = document.getElementById('avatarResult');
    result.style.display = 'block';
    result.className     = 'avatar-result ' + (ok ? 'ok' : 'err');
    result.textContent   = msg;
}

function refreshAvatarDisplay(url) {
    var ad     = document.getElementById('avatarDisplay');
    var isSvg  = url.toLowerCase().endsWith('.svg');
    if (isSvg) {
        ad.innerHTML = '<object data="' + url + '" type="image/svg+xml" '
            + 'style="width:100%;height:100%;border-radius:50%;pointer-events:none;" '
            + 'onerror="this.style.display=\'none\'"></object>';
    } else {
        ad.innerHTML = '<img src="' + url + '" alt="Avatar" '
            + 'onerror="this.style.display=\'none\'" '
            + 'style="width:100%;height:100%;object-fit:cover;border-radius:50%;">';
    }
}

document.getElementById('setAvatarBtn').addEventListener('click', function() {
    var url = document.getElementById('avatarUrlInput').value.trim();
    if (!url) return;
    showAvatarResult(null, 'Fetching…');
    document.getElementById('avatarResult').style.display = 'block';
    document.getElementById('avatarResult').className     = 'avatar-result';

    fetch('/profile/update-avatar', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ avatar_url: url })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.ok) {
            showAvatarResult(true, 'Avatar updated.');
            refreshAvatarDisplay(url);
        } else {
            showAvatarResult(false, data.error || 'Failed.');
        }
    })
    .catch(function(e) {
        showAvatarResult(false, 'Request failed: ' + e.message);
    });
});

function uploadAvatarFile(input) {
    if (!input.files || !input.files[0]) return;
    var file     = input.files[0];
    var formData = new FormData();
    formData.append('avatar', file);

    showAvatarResult(null, 'Uploading…');
    document.getElementById('avatarResult').style.display = 'block';
    document.getElementById('avatarResult').className     = 'avatar-result';

    fetch('/profile/upload-avatar', {
        method: 'POST',
        body:   formData
    })
    .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
    })
    .then(function(data) {
        if (data.ok) {
            showAvatarResult(true, 'Avatar uploaded successfully.');
            document.getElementById('avatarUrlInput').value = data.url;
            refreshAvatarDisplay(data.url);
        } else {
            showAvatarResult(false, data.error || 'Upload failed.');
        }
    })
    .catch(function(e) {
        showAvatarResult(false, 'Upload failed: ' + e.message);
    });


    input.value = '';
}
</script>
