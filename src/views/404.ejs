<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found | Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-100);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 32px 24px;
        }

        /* ── NAV STRIP ── */
        .mini-nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: var(--purple-deep);
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(59,7,100,0.3);
        }

        .brand-logo {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--white);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .brand-logo .dot {
            width: 7px;
            height: 7px;
            background: var(--purple-light);
            border-radius: 50%;
        }

        .nav-home-btn {
            color: rgba(255,255,255,0.75);
            font-size: 0.85rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            transition: all 0.2s;
        }

        .nav-home-btn:hover {
            color: var(--white);
            background: rgba(255,255,255,0.1);
        }

        /* ── MAIN CONTENT ── */
        .error-wrap {
            text-align: center;
            max-width: 520px;
            margin-top: 64px;
        }

        /* Stylised 404 */
        .error-visual {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 8px;
        }

        .error-num {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: clamp(90px, 18vw, 130px);
            line-height: 1;
            background: linear-gradient(135deg, var(--purple-deep), var(--purple-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -4px;
        }

        .error-icon-wrap {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            width: 72px;
            height: 72px;
            background: var(--gray-100);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid var(--gray-200);
        }

        .error-icon-wrap i {
            font-size: 2rem;
            color: var(--purple-mid);
        }

        .error-wrap h1 {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.6rem;
            color: var(--black);
            margin-bottom: 10px;
        }

        .error-wrap p {
            color: var(--gray-500);
            font-size: 0.92rem;
            line-height: 1.65;
            margin-bottom: 36px;
        }

        /* ── BUTTONS ── */
        .error-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary-purple {
            background: var(--purple-deep);
            color: var(--white);
            border: none;
            border-radius: 10px;
            padding: 12px 28px;
            font-size: 0.9rem;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s, transform 0.15s;
        }

        .btn-primary-purple:hover {
            background: var(--purple-mid);
            color: var(--white);
            transform: translateY(-1px);
        }

        .btn-outline-purple {
            background: transparent;
            color: var(--purple-mid);
            border: 1.5px solid var(--purple-mid);
            border-radius: 10px;
            padding: 11px 28px;
            font-size: 0.9rem;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-outline-purple:hover {
            background: var(--purple-pale);
            color: var(--purple-deep);
            transform: translateY(-1px);
        }

        /* ── DIVIDER ── */
        .error-divider {
            width: 48px;
            height: 3px;
            background: linear-gradient(90deg, var(--purple-mid), var(--purple-light));
            border-radius: 2px;
            margin: 24px auto;
        }

        /* ── SUGGESTED LINKS ── */
        .suggest-links {
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 28px;
        }

        .suggest-link {
            color: var(--gray-500);
            font-size: 0.82rem;
            text-decoration: none;
            padding: 6px 14px;
            border-radius: 20px;
            border: 1.5px solid var(--gray-200);
            background: var(--white);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .suggest-link:hover {
            border-color: var(--purple-light);
            color: var(--purple-mid);
            background: var(--purple-pale);
        }

        .footer-note {
            margin-top: 48px;
            color: var(--gray-500);
            font-size: 0.78rem;
        }

        .footer-note strong { color: var(--purple-light); }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="mini-nav">
    <a href="/" class="brand-logo">Pwnshop<span class="dot"></span></a>
    <a href="/" class="nav-home-btn"><i class="bi bi-house"></i> Go Home</a>
</nav>

<div class="error-wrap">

    <div class="error-visual">
        <div class="error-num">404</div>
    </div>

    <div class="error-divider"></div>

    <h1>Page not found</h1>
    <p>
        The page you're looking for doesn't exist or may have been moved.
        Check the URL or head back to the homepage to find what you need.
    </p>

    <div class="error-actions">
        <a href="/" class="btn-primary-purple">
            <i class="bi bi-house-fill"></i> Back to Home
        </a>
        <% if (user) { %>
            <a href="/profile" class="btn-outline-purple">
                <i class="bi bi-person"></i> My Profile
            </a>
        <% } else { %>
            <a href="/login" class="btn-outline-purple">
                <i class="bi bi-box-arrow-in-right"></i> Sign In
            </a>
        <% } %>
    </div>

    <div class="suggest-links">
        <a href="/category/all"         class="suggest-link"><i class="bi bi-grid"></i> All Products</a>
        <a href="/category/electronics" class="suggest-link"><i class="bi bi-lightning-charge"></i> Electronics</a>
        <a href="/category/fashion"     class="suggest-link"><i class="bi bi-bag"></i> Fashion</a>
        <a href="/category/phones"      class="suggest-link"><i class="bi bi-phone"></i> Phones</a>
    </div>

</div>

<div class="footer-note">
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</div>

    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
