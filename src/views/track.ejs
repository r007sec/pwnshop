<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Your Order - Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'DM Sans', sans-serif; background: var(--gray-100); color: var(--black); }

        /* ── NAVBAR ── */
        .topbar { background: var(--purple-deep); padding: 0; position: sticky; top: 0; z-index: 1000; box-shadow: 0 2px 16px rgba(59,7,100,0.4); }
        .topbar .container { display: flex; align-items: center; gap: 16px; padding: 12px 24px; }
        .navbar-brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--white) !important; text-decoration: none; display: flex; align-items: center; gap: 6px; }
        .navbar-brand .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .nav-right { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0 0 0 auto; padding: 0; }
        .user-chip { text-decoration: none; background: rgba(168,85,247,0.2); border: 1px solid rgba(168,85,247,0.4); color: var(--white) !important; border-radius: 20px; padding: 5px 14px; font-size: 0.85rem; font-weight: 600; }
        .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.8) !important; border-radius: 8px; padding: 5px 12px; font-size: 0.83rem; text-decoration: none; }
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(135deg, var(--purple-deep) 0%, #4c0099 100%);
            padding: 60px 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: rgba(168,85,247,0.1);
            border-radius: 50%;
            top: -100px; right: -100px;
        }
        .hero::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: rgba(192,38,211,0.08);
            border-radius: 50%;
            bottom: -80px; left: -80px;
        }
        .hero-content { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
        .hero-icon { width: 64px; height: 64px; background: rgba(255,255,255,0.1); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 1.8rem; color: var(--white); }
        .hero h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem; color: var(--white); margin-bottom: 10px; }
        .hero p { color: rgba(255,255,255,0.7); font-size: 0.95rem; margin-bottom: 36px; }

        /* ── SEARCH CARD ── */
        .search-card {
            background: var(--white);
            border-radius: 16px;
            padding: 28px 28px 24px;
            box-shadow: 0 8px 32px rgba(59,7,100,0.18);
            max-width: 500px;
            margin: 0 auto;
        }
        .f-label { font-size: 0.78rem; font-weight: 600; color: var(--black); margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; display: block; }
        .f-field { border: 1.5px solid var(--gray-200); border-radius: 10px; padding: 11px 14px; font-size: 0.9rem; font-family: 'DM Sans', sans-serif; width: 100%; outline: none; transition: border-color 0.2s, box-shadow 0.2s; color: var(--black); background: var(--white); }
        .f-field:focus { border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
        .f-field::placeholder { color: #b0afc0; }
        .btn-track { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 13px; font-size: 0.92rem; font-weight: 700; font-family: 'DM Sans', sans-serif; width: 100%; cursor: pointer; transition: background 0.2s, transform 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 4px; }
        .btn-track:hover { background: var(--purple-mid); transform: translateY(-1px); }
        .alert-err { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; border-radius: 8px; padding: 10px 14px; font-size: 0.83rem; display: flex; align-items: center; gap: 8px; margin-bottom: 18px; }

        /* ── INFO STRIPS ── */
        .info-strip { max-width: 860px; margin: 48px auto; padding: 0 20px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .info-item { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); padding: 20px; text-align: center; }
        .info-item i { font-size: 1.5rem; color: var(--purple-mid); display: block; margin-bottom: 10px; }
        .info-item h4 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.88rem; color: var(--black); margin-bottom: 4px; }
        .info-item p { font-size: 0.78rem; color: var(--gray-500); }

        footer { background: var(--purple-deep); color: rgba(255,255,255,0.6); text-align: center; padding: 24px; font-size: 0.85rem; margin-top: 60px; }
        footer strong { color: var(--purple-light); }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <ul class="nav-right">
            <li><a class="nav-link-plain" href="/">Home</a></li>
            <% if (user) { %>
                <li><a href="/profile" class="user-chip"><%= user.username %></a></li>
                <li><a href="/logout" class="btn-logout">Logout</a></li>
            <% } else { %>
                <li><a href="/login" class="nav-link-plain">Login</a></li>
            <% } %>
        </ul>
    </div>
</nav>

<div class="hero">
    <div class="hero-content">
        <div class="hero-icon"><i class="bi bi-geo-alt-fill"></i></div>
        <h1>Track Your Order</h1>
        <p>Enter your order number and email address to get real-time updates on your delivery.</p>

        <div class="search-card">
            <% if (error) { %>
                <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i> <%= error %></div>
            <% } %>

            <form method="POST" action="/track">
                <div class="mb-3">
                    <label class="f-label">Order Number</label>
                    <input type="text" class="f-field" name="order_id" placeholder="e.g. 1042" required>
                </div>
                <div class="mb-4">
                    <label class="f-label">Email Address</label>
                    <input type="email" class="f-field" name="email" placeholder="you@example.com" required>
                </div>
                <button type="submit" class="btn-track">
                    <i class="bi bi-search"></i> Track Order
                </button>
            </form>
        </div>
    </div>
</div>

<div class="info-strip">
    <div class="info-item">
        <i class="bi bi-clock-history"></i>
        <h4>Real-Time Updates</h4>
        <p>See every status change from the moment your order is placed to delivery.</p>
    </div>
    <div class="info-item">
        <i class="bi bi-geo-alt"></i>
        <h4>Live Map</h4>
        <p>View your order's current delivery location on an interactive map.</p>
    </div>
    <div class="info-item">
        <i class="bi bi-bell"></i>
        <h4>Status History</h4>
        <p>Full timeline of every update with timestamps and notes from our team.</p>
    </div>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
