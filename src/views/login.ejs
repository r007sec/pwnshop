<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root {
            --purple-deep:  #3B0764;
            --purple-mid:   #6D28D9;
            --purple-light: #A855F7;
            --purple-pale:  #F3E8FF;
            --black:        #0D0D0D;
            --white:        #FFFFFF;
            --gray-100:     #F8F5FF;
            --gray-200:     #EDE9F6;
            --gray-500:     #6B7280;
            --accent:       #C026D3;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'DM Sans', sans-serif; background: var(--gray-100); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .auth-card { background: var(--white); border-radius: 20px; box-shadow: 0 8px 40px rgba(59,7,100,0.13); width: 100%; max-width: 920px; display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; min-height: 560px; }
        .auth-panel-left { background: linear-gradient(145deg, var(--purple-deep), var(--purple-mid)); padding: 48px 40px; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; }
        .auth-panel-left::before { content: ''; position: absolute; width: 260px; height: 260px; background: rgba(168,85,247,0.15); border-radius: 50%; top: -60px; right: -80px; }
        .auth-panel-left::after { content: ''; position: absolute; width: 180px; height: 180px; background: rgba(192,38,211,0.12); border-radius: 50%; bottom: -40px; left: -40px; }
        .brand-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.7rem; color: var(--white); text-decoration: none; display: flex; align-items: center; gap: 8px; position: relative; z-index: 1; }
        .brand-logo .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .panel-body { position: relative; z-index: 1; }
        .panel-body h2 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.9rem; color: var(--white); line-height: 1.25; margin-bottom: 14px; }
        .panel-body p { color: rgba(255,255,255,0.7); font-size: 0.9rem; line-height: 1.6; }
        .panel-perks { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 10px; }
        .perk-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.85); font-size: 0.85rem; }
        .perk-item i { font-size: 1rem; color: var(--purple-light); flex-shrink: 0; }
        .auth-panel-right { padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; }
        .auth-panel-right h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.5rem; color: var(--black); margin-bottom: 6px; }
        .auth-panel-right .subtitle { color: var(--gray-500); font-size: 0.875rem; margin-bottom: 28px; }
        .form-label { font-size: 0.8rem; font-weight: 600; color: var(--black); margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; }
        .input-group-auth { display: flex; gap: 0; border: 1.5px solid var(--gray-200); border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
        .input-group-auth:focus-within { border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
        .input-group-auth select { border: none; outline: none; background: var(--gray-100); padding: 11px 10px; font-size: 0.8rem; font-family: 'DM Sans', sans-serif; color: var(--black); max-width: 96px; border-right: 1.5px solid var(--gray-200); cursor: pointer; }
        .input-group-auth input, .form-field { border: 1.5px solid var(--gray-200); border-radius: 10px; padding: 11px 14px; font-size: 0.9rem; font-family: 'DM Sans', sans-serif; width: 100%; outline: none; transition: border-color 0.2s, box-shadow 0.2s; color: var(--black); }
        .input-group-auth input { border: none; border-radius: 0; flex: 1; }
        .form-field:focus { border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
        .form-field::placeholder { color: #b0afc0; }
        .pw-wrap { position: relative; }
        .pw-wrap .form-field { padding-right: 42px; }
        .pw-toggle { position: absolute; right: 13px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--gray-500); cursor: pointer; font-size: 1rem; padding: 0; line-height: 1; }
        .pw-toggle:hover { color: var(--purple-mid); }
        .btn-auth-primary { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 12px; font-size: 0.9rem; font-weight: 700; font-family: 'DM Sans', sans-serif; width: 100%; cursor: pointer; transition: background 0.2s, transform 0.15s; letter-spacing: 0.3px; }
        .btn-auth-primary:hover { background: var(--purple-mid); transform: translateY(-1px); }
        .divider { display: flex; align-items: center; gap: 10px; margin: 20px 0; color: var(--gray-500); font-size: 0.78rem; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--gray-200); }
        .btn-social { display: flex; align-items: center; justify-content: center; gap: 10px; border-radius: 10px; padding: 10px; font-size: 0.85rem; font-weight: 600; font-family: 'DM Sans', sans-serif; width: 100%; cursor: pointer; transition: all 0.2s; text-decoration: none; }
        .btn-social-fb { background: #1877F2; color: var(--white); border: none; }
        .btn-social-fb:hover { background: #1560c9; color: var(--white); }
        .btn-social-google { background: var(--white); color: var(--black); border: 1.5px solid var(--gray-200); }
        .btn-social-google:hover { background: var(--gray-100); color: var(--black); }
        .auth-footer { margin-top: 22px; text-align: center; font-size: 0.82rem; color: var(--gray-500); }
        .auth-footer a { color: var(--purple-mid); font-weight: 600; text-decoration: none; }
        .auth-footer a:hover { color: var(--accent); }
        .terms-note { font-size: 0.75rem; color: var(--gray-500); text-align: center; margin-top: 14px; line-height: 1.5; }
        .terms-note a { color: var(--purple-mid); font-weight: 600; text-decoration: none; }
        .alert-auth { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; border-radius: 8px; padding: 10px 14px; font-size: 0.83rem; display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
        @media (max-width: 640px) { .auth-card { grid-template-columns: 1fr; } .auth-panel-left { display: none; } .auth-panel-right { padding: 36px 28px; } }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>
<div class="auth-card">
    <div class="auth-panel-left">
        <a href="/" class="brand-logo">Pwnshop<span class="dot"></span></a>
        <div class="panel-body">
            <h2>Welcome back to the shop.</h2>
            <p>Log in to access your orders, wishlist, and exclusive deals tailored for you.</p>
        </div>
        <div class="panel-perks">
            <div class="perk-item"><i class="bi bi-shield-check-fill"></i><span>Secure, encrypted login</span></div>
            <div class="perk-item"><i class="bi bi-box-seam"></i><span>Track orders in real time</span></div>
            <div class="perk-item"><i class="bi bi-stars"></i><span>Members get exclusive deals</span></div>
        </div>
    </div>

    <div class="auth-panel-right">
        <h3>Sign in</h3>
        <p class="subtitle">Enter your credentials to access your account.</p>

        <% if (error) { %>
            <div class="alert-auth"><i class="bi bi-exclamation-circle-fill"></i> <%= error %></div>
        <% } %>

        <form method="POST" action="/login">

            <input type="hidden" name="next" value="<%= next || '' %>">

            <div class="mb-3">
                <label class="form-label">Username / Email / Phone</label>
                <div class="input-group-auth">
                    <select name="country_code" id="countryCode">
                        <option value="+234 NG">+234 NG</option>
                        <option value="+1 US">+1 US</option>
                        <option value="+44 UK">+44 UK</option>
                    </select>
                    <input type="text" name="username" value="<%= username || '' %>" placeholder="Mobile, email or username" required>
                </div>
            </div>

            <div class="mb-4">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                    <label class="form-label" style="margin:0">Password</label>
                    <a href="/forgot-password" style="font-size:0.78rem;color:var(--purple-mid);font-weight:600;text-decoration:none;">Forgot password?</a>
                </div>
                <div class="pw-wrap">
                    <input type="password" class="form-field" name="password" id="passwordField" placeholder="Enter your password" required>
                    <button type="button" class="pw-toggle" id="pwToggle"><i class="bi bi-eye" id="pwIcon"></i></button>
                </div>
            </div>

            <button type="submit" class="btn-auth-primary">Sign In</button>
        </form>

        <div class="divider">or continue with</div>
        <div class="d-flex flex-column gap-2">
            <button class="btn-social btn-social-fb" type="button"><i class="bi bi-facebook"></i> Continue with Facebook</button>
            <button class="btn-social btn-social-google" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                Continue with Google
            </button>
        </div>

        <div class="auth-footer">Don't have an account? <a href="/register">Create one</a></div>
        <p class="terms-note">By signing in you agree to Pwnshop's <a href="#">Terms &amp; Conditions</a> and <a href="#">Privacy Policy</a>.</p>
    </div>
</div>

<script>
    const usernameInput = document.querySelector('input[name="username"]');
    const countryCode   = document.getElementById('countryCode');
    usernameInput.addEventListener('input', function () {
        countryCode.style.display = /^[a-zA-Z@]/.test(this.value) ? 'none' : '';
    });
    document.getElementById('pwToggle').addEventListener('click', function () {
        const field = document.getElementById('passwordField');
        const icon  = document.getElementById('pwIcon');
        if (field.type === 'password') { field.type = 'text'; icon.className = 'bi bi-eye-slash'; }
        else { field.type = 'password'; icon.className = 'bi bi-eye'; }
    });
</script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
