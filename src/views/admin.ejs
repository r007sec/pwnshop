<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Pwnshop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <style>
        :root{--purple-deep:#3B0764;--purple-mid:#6D28D9;--purple-light:#A855F7;--purple-pale:#F3E8FF;--black:#0D0D0D;--white:#FFFFFF;--gray-100:#F8F5FF;--gray-200:#EDE9F6;--gray-500:#6B7280;--accent:#C026D3;--danger:#dc2626;}
        *{box-sizing:border-box;}
        body{font-family:'DM Sans',sans-serif;background:var(--gray-100);color:var(--black);margin:0;display:flex;min-height:100vh;}

        /* ── SIDEBAR ── */
        .sidebar{width:220px;background:var(--purple-deep);flex-shrink:0;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;}
        .sb-brand{padding:18px 16px 14px;display:flex;align-items:center;gap:0;border-bottom:1px solid rgba(255,255,255,0.1);}
        .sb-brand-name{font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;color:var(--white);white-space:nowrap;}
        .sb-brand .dot{width:6px;height:6px;background:var(--purple-light);border-radius:50%;margin:0 4px;}
        .admin-tag{background:var(--danger);color:var(--white);font-size:0.5rem;font-weight:800;letter-spacing:0.8px;text-transform:uppercase;padding:2px 6px;border-radius:4px;margin-left:6px;flex-shrink:0;white-space:nowrap;line-height:1.4;}
        .sb-section{padding:14px 12px 6px;font-size:0.62rem;font-weight:700;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:1.2px;}
        .sb-link{display:flex;align-items:center;gap:10px;padding:9px 16px;color:rgba(255,255,255,0.65);font-size:0.85rem;font-weight:500;text-decoration:none;border-radius:8px;margin:2px 8px;transition:all 0.18s;}
        .sb-link:hover{background:rgba(255,255,255,0.1);color:var(--white);}
        .sb-link.active{background:rgba(255,255,255,0.15);color:var(--white);font-weight:700;}
        .sb-link i{font-size:1rem;width:18px;text-align:center;flex-shrink:0;}
        .sb-link .sb-badge{margin-left:auto;background:rgba(255,255,255,0.15);color:var(--white);font-size:0.65rem;border-radius:20px;padding:1px 8px;}
        .sb-link.active .sb-badge{background:var(--purple-light);}
        .sb-bottom{margin-top:auto;padding:14px 8px;border-top:1px solid rgba(255,255,255,0.1);}
        .sb-user{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;background:rgba(255,255,255,0.07);}
        .sb-avatar{width:32px;height:32px;background:var(--purple-mid);border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:0.85rem;color:var(--white);}
        .sb-uname{font-size:0.8rem;color:var(--white);font-weight:600;}
        .sb-urole{font-size:0.68rem;color:rgba(255,255,255,0.5);}

        /* ── MAIN ── */
        .main-area{flex:1;display:flex;flex-direction:column;min-width:0;overflow-x:hidden;}
        .topbar{background:var(--white);border-bottom:1.5px solid var(--gray-200);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
        .topbar-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:var(--black);}
        .topbar-actions{display:flex;align-items:center;gap:10px;}
        .btn-tb{border-radius:8px;padding:7px 16px;font-size:0.82rem;font-weight:700;font-family:'DM Sans',sans-serif;border:none;cursor:pointer;transition:all 0.18s;text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
        .btn-tb-outline{background:transparent;color:var(--gray-500);border:1.5px solid var(--gray-200);}
        .btn-tb-outline:hover{background:var(--gray-100);color:var(--black);}
        .btn-tb-primary{background:var(--purple-deep);color:var(--white);}
        .btn-tb-primary:hover{background:var(--purple-mid);color:var(--white);}
        .btn-tb-green{background:#16a34a;color:var(--white);}
        .btn-tb-green:hover{background:#15803d;}
        .btn-tb-danger{background:#fef2f2;color:var(--danger);border:1px solid #fecaca;}
        .btn-tb-danger:hover{background:var(--danger);color:var(--white);}
        .btn-tb-amber{background:#fffbeb;color:#92400e;border:1px solid #fcd34d;}
        .btn-tb-amber:hover{background:#d97706;color:var(--white);}

        .page-content{padding:28px;flex:1;}

        /* Flash */
        .flash-ok{background:#f0fdf4;border:1.5px solid #86efac;color:#15803d;border-radius:10px;padding:12px 16px;margin-bottom:20px;display:flex;align-items:center;gap:8px;font-size:0.85rem;}
        .flash-err{background:#fef2f2;border:1.5px solid #fecaca;color:#dc2626;border-radius:10px;padding:12px 16px;margin-bottom:20px;display:flex;align-items:center;gap:8px;font-size:0.85rem;}

        /* Stats cards */
        .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;}
        .stat-card{background:var(--white);border-radius:14px;border:1.5px solid var(--gray-200);padding:20px 22px;}
        .stat-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
        .stat-label{font-size:0.72rem;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.5px;}
        .stat-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;}
        .si-purple{background:var(--purple-pale);color:var(--purple-mid);}
        .si-blue{background:#eff6ff;color:#2563eb;}
        .si-amber{background:#fffbeb;color:#d97706;}
        .si-green{background:#f0fdf4;color:#16a34a;}
        .stat-value{font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;color:var(--black);line-height:1;}
        .stat-sub{font-size:0.72rem;color:var(--gray-500);margin-top:6px;}

        /* Section card */
        .section-card{background:var(--white);border-radius:14px;border:1.5px solid var(--gray-200);overflow:hidden;margin-bottom:22px;}
        .section-head{padding:16px 22px;border-bottom:1.5px solid var(--gray-200);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
        .section-head h3{font-family:'Syne',sans-serif;font-weight:800;font-size:0.95rem;color:var(--black);margin:0;display:flex;align-items:center;gap:7px;}
        .section-head h3 i{color:var(--purple-mid);}
        .count-tag{background:var(--purple-pale);color:var(--purple-mid);font-size:0.7rem;font-weight:700;border-radius:20px;padding:2px 10px;}

        /* Search bar */
        .search-bar{display:flex;gap:8px;align-items:center;}
        .search-input{border:1.5px solid var(--gray-200);border-radius:9px;padding:8px 14px;font-size:0.85rem;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);color:var(--black);min-width:240px;transition:border-color 0.2s;}
        .search-input:focus{border-color:var(--purple-mid);}
        .search-input::placeholder{color:#b0afc0;}

        /* Action panel */
        .action-panel{padding:16px 22px;background:var(--gray-100);border-bottom:1.5px solid var(--gray-200);}
        .ap-label{font-size:0.72rem;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
        .ap-label i{color:var(--purple-mid);}
        .action-row{display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;}
        .ap-field{border:1.5px solid var(--gray-200);border-radius:9px;padding:9px 12px;font-size:0.85rem;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);color:var(--black);transition:border-color 0.2s;}
        .ap-field:focus{border-color:var(--purple-mid);}
        .ap-field::placeholder{color:#b0afc0;}
        .ap-select{border:1.5px solid var(--gray-200);border-radius:9px;padding:9px 12px;font-size:0.85rem;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);color:var(--black);cursor:pointer;}

        /* Table */
        .table-wrap{overflow-x:auto;}
        table{width:100%;border-collapse:collapse;}
        th{padding:10px 16px;text-align:left;font-size:0.68rem;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.5px;background:var(--gray-100);border-bottom:1.5px solid var(--gray-200);white-space:nowrap;}
        td{padding:11px 16px;font-size:0.84rem;border-bottom:1px solid var(--gray-200);color:var(--black);vertical-align:middle;}
        tr:last-child td{border-bottom:none;}
        tr:hover td{background:#fafafa;}
        .td-id{color:var(--gray-500);font-family:monospace;font-size:0.78rem;}
        .td-bold{font-weight:600;}
        .td-mono{font-family:monospace;font-size:0.78rem;color:var(--gray-500);}
        .td-amount{font-family:'Syne',sans-serif;font-weight:700;font-size:0.88rem;color:var(--purple-mid);}
        .btn-tbl{border:none;border-radius:6px;padding:4px 10px;font-size:0.72rem;font-weight:700;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.15s;display:inline-flex;align-items:center;gap:4px;}
        .btn-tbl-red{background:#fef2f2;color:var(--danger);border:1px solid #fecaca;}
        .btn-tbl-red:hover{background:var(--danger);color:var(--white);}
        .btn-tbl-purple{background:var(--purple-pale);color:var(--purple-mid);border:1px solid rgba(109,40,217,0.2);}
        .btn-tbl-purple:hover{background:var(--purple-mid);color:var(--white);}
        .btn-tbl-amber{background:#fffbeb;color:#92400e;border:1px solid #fcd34d;}
        .btn-tbl-amber:hover{background:#d97706;color:var(--white);}
        .status-select{border:1.5px solid var(--gray-200);border-radius:7px;padding:4px 8px;font-size:0.78rem;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);cursor:pointer;color:var(--black);}

        /* Badges */
        .badge{display:inline-flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:700;border-radius:6px;padding:3px 9px;text-transform:uppercase;letter-spacing:0.3px;}
        .b-admin{background:rgba(220,38,38,0.1);color:var(--danger);border:1px solid rgba(220,38,38,0.2);}
        .b-seller{background:var(--purple-pale);color:var(--purple-mid);border:1px solid rgba(109,40,217,0.2);}
        .b-user{background:var(--gray-100);color:var(--gray-500);border:1px solid var(--gray-200);}
        .b-pending{background:#fffbeb;color:#92400e;border:1px solid #fcd34d;}
        .b-processing{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;}
        .b-shipped{background:#ecfeff;color:#0e7490;border:1px solid #a5f3fc;}
        .b-delivered{background:#f0fdf4;color:#15803d;border:1px solid #86efac;}
        .b-cancelled{background:#fef2f2;color:var(--danger);border:1px solid #fecaca;}
        .b-active{background:#f0fdf4;color:#15803d;border:1px solid #86efac;}
        .b-inactive{background:#fef2f2;color:var(--danger);border:1px solid #fecaca;}

        /* Security tab */
        .sec-card{background:var(--white);border-radius:14px;border:1.5px solid var(--gray-200);padding:28px;margin-bottom:16px;}
        .sec-card h3{font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:var(--black);margin-bottom:8px;display:flex;align-items:center;gap:8px;}
        .vuln-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:20px;}
        .vuln-item{background:var(--gray-100);border-radius:10px;border:1.5px solid var(--gray-200);padding:16px;}
        .vuln-item .v-title{font-family:'Syne',sans-serif;font-weight:700;font-size:0.82rem;color:var(--black);margin-bottom:4px;display:flex;align-items:center;gap:7px;}
        .vuln-item .v-title i{color:var(--danger);}
        .vuln-item .v-desc{font-size:0.78rem;color:var(--gray-500);line-height:1.55;}
        .vuln-item .v-status{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:0.7rem;font-weight:700;border-radius:20px;padding:2px 10px;}
        .v-open{background:#fef2f2;color:var(--danger);}
        .v-info{background:var(--purple-pale);color:var(--purple-mid);}

        .empty-state{text-align:center;padding:60px 20px;}
        .empty-state i{font-size:3rem;color:var(--gray-200);display:block;margin-bottom:14px;}
        .empty-state p{color:var(--gray-500);font-size:0.85rem;}

        /* ── CONFIRM MODAL ── */
        .modal-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:2000;align-items:center;justify-content:center;}
        .modal-backdrop.open{display:flex;}
        .modal-box{background:var(--white);border-radius:16px;padding:32px 28px;max-width:400px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.25);animation:modalIn 0.18s ease;}
        @keyframes modalIn{from{transform:scale(0.95);opacity:0;}to{transform:scale(1);opacity:1;}}
        .modal-icon{width:48px;height:48px;background:#fef2f2;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#dc2626;margin-bottom:16px;}
        .modal-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;color:var(--black);margin-bottom:6px;}
        .modal-body{font-size:0.85rem;color:var(--gray-500);line-height:1.6;margin-bottom:24px;}
        .modal-actions{display:flex;gap:10px;justify-content:flex-end;}
        .btn-modal-cancel{background:var(--white);border:1.5px solid var(--gray-200);color:var(--gray-500);border-radius:9px;padding:9px 20px;font-size:0.85rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.18s;}
        .btn-modal-cancel:hover{background:var(--gray-100);color:var(--black);}
        .btn-modal-confirm{background:#dc2626;border:none;color:var(--white);border-radius:9px;padding:9px 20px;font-size:0.85rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background 0.18s;}
        .btn-modal-confirm:hover{background:#b91c1c;}
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="sidebar">
    <div class="sb-brand">
        <a href="/" style="text-decoration:none;display:flex;align-items:center;min-width:0;">
            <span class="sb-brand-name">Pwnshop</span><span class="dot"></span>
        </a>
        <span class="admin-tag">Admin</span>
    </div>

    <div class="sb-section">Overview</div>
    <a href="/admin/stats"    class="sb-link <%= tab==='stats'    ? 'active':'' %>"><i class="bi bi-grid-1x2"></i> Dashboard</a>

    <div class="sb-section">Manage</div>
    <a href="/admin/users"    class="sb-link <%= tab==='users'    ? 'active':'' %>"><i class="bi bi-people"></i> Users</a>
    <a href="/admin/orders"   class="sb-link <%= tab==='orders'   ? 'active':'' %>"><i class="bi bi-bag"></i> Orders</a>
    <a href="/admin/products" class="sb-link <%= tab==='products' ? 'active':'' %>"><i class="bi bi-box-seam"></i> Products</a>
    <a href="/admin/reviews"  class="sb-link <%= tab==='reviews'  ? 'active':'' %>"><i class="bi bi-chat-square-text"></i> Reviews</a>
    <a href="/admin/coupons"  class="sb-link <%= tab==='coupons'  ? 'active':'' %>"><i class="bi bi-ticket-perforated"></i> Coupons</a>

    <div class="sb-section">System</div>
    <a href="/admin/security" class="sb-link <%= tab==='security' ? 'active':'' %>"><i class="bi bi-shield-exclamation"></i> Security</a>
    <a href="/admin/export-orders" class="sb-link"><i class="bi bi-download"></i> Export CSV</a>
    <a href="/vulnerabilities" class="sb-link"><i class="bi bi-bug"></i> Vulns</a>

    <div class="sb-bottom">
        <div class="sb-user">
            <div class="sb-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
            <div>
                <div class="sb-uname"><%= user.username %></div>
                <div class="sb-urole">Administrator</div>
            </div>
        </div>
        <a href="/logout" style="display:flex;align-items:center;gap:8px;padding:10px 12px;margin-top:8px;color:rgba(255,255,255,0.6);font-size:0.82rem;text-decoration:none;border-radius:8px;transition:all 0.18s;">
            <i class="bi bi-box-arrow-left"></i> Sign out
        </a>
    </div>
</nav>

<div class="main-area">


    <div class="topbar">
        <div class="topbar-title">
            <% if(tab==='stats')    { %>Dashboard<% } %>
            <% if(tab==='users')    { %>Users<% } %>
            <% if(tab==='orders')   { %>Orders<% } %>
            <% if(tab==='products') { %>Products<% } %>
            <% if(tab==='reviews')  { %>Reviews<% } %>
            <% if(tab==='security') { %>Security<% } %>
            <% if(tab==='coupons')  { %>Coupons<% } %>
        </div>
        <div class="topbar-actions">
            <button type="button" class="btn-tb btn-tb-danger" onclick="openLabResetModal()"><i class="bi bi-arrow-repeat"></i> Reset Lab</button>
            <a href="/" class="btn-tb btn-tb-outline"><i class="bi bi-shop"></i> View Store</a>
            <% if(tab==='orders') { %>
                <a href="/admin/export-orders" class="btn-tb btn-tb-primary"><i class="bi bi-download"></i> Export CSV</a>
            <% } %>
        </div>
    </div>

    <div class="page-content">

        <% if (success) { %><div class="flash-ok"><i class="bi bi-check-circle-fill"></i> <%= success %></div><% } %>
        <% if (error)   { %><div class="flash-err"><i class="bi bi-exclamation-circle-fill"></i> <%= error %></div><% } %>




        <% if (tab === 'stats' && stats) { %>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-top"><span class="stat-label">Total Users</span><span class="stat-icon si-purple"><i class="bi bi-people-fill"></i></span></div>
                <div class="stat-value"><%= stats.users %></div>
                <div class="stat-sub"><%= stats.sellers %> sellers registered</div>
            </div>
            <div class="stat-card">
                <div class="stat-top"><span class="stat-label">Total Orders</span><span class="stat-icon si-blue"><i class="bi bi-bag-fill"></i></span></div>
                <div class="stat-value"><%= stats.orders %></div>
                <div class="stat-sub"><%= stats.pending %> pending fulfilment</div>
            </div>
            <div class="stat-card">
                <div class="stat-top"><span class="stat-label">Products</span><span class="stat-icon si-amber"><i class="bi bi-box-seam"></i></span></div>
                <div class="stat-value"><%= stats.products %></div>
                <div class="stat-sub"><%= stats.active %> active listings</div>
            </div>
            <div class="stat-card">
                <div class="stat-top"><span class="stat-label">Revenue</span><span class="stat-icon si-green"><i class="bi bi-graph-up-arrow"></i></span></div>
                <div class="stat-value" style="font-size:1.4rem;">&#8358;<%= stats.revenue %></div>
                <div class="stat-sub">from delivered orders</div>
            </div>
        </div>
        <div class="section-card">
            <div class="section-head"><h3><i class="bi bi-lightning-charge"></i> Quick Actions</h3></div>
            <div style="padding:20px 22px;display:flex;gap:12px;flex-wrap:wrap;">
                <a href="/admin/users"    class="btn-tb btn-tb-primary"><i class="bi bi-people"></i> Manage Users</a>
                <a href="/admin/orders"   class="btn-tb btn-tb-outline"><i class="bi bi-bag"></i> View Orders</a>
                <a href="/admin/products" class="btn-tb btn-tb-outline"><i class="bi bi-box-seam"></i> Products</a>
                <a href="/admin/export-orders" class="btn-tb btn-tb-green"><i class="bi bi-download"></i> Export Orders CSV</a>
            </div>
        </div>
        <% } %>




        <% if (tab === 'users') { %>
        <div class="section-card">
            <div class="section-head">
                <h3><i class="bi bi-person-plus"></i> Promote to Seller</h3>
            </div>
            <div class="action-panel">
                <form method="POST" action="/admin/make-seller">
                    <div class="action-row">
                        <input type="email" class="ap-field" name="email" placeholder="Enter user email address" style="min-width:280px;" required>
                        <button type="submit" class="btn-tb btn-tb-green"><i class="bi bi-arrow-up-circle"></i> Make Seller</button>
                    </div>
                </form>
            </div>
            <div class="action-panel" style="border-top:1.5px solid var(--gray-200);">
                <div class="ap-label"><i class="bi bi-wallet2"></i> Top Up Wallet</div>
                <form method="POST" action="/admin/topup-wallet">
                    <div class="action-row">
                        <select class="ap-select" name="user_id" required>
                            <option value="">Select user…</option>
                            <% users.forEach(u=>{ %><option value="<%= u.id %>"><%= u.username %> (₦<%= parseFloat(u.wallet_amount||0).toFixed(2) %>)</option><% }); %>
                        </select>
                        <input type="number" class="ap-field" name="amount" placeholder="Amount (₦)" min="1" step="0.01" style="width:160px;" required>
                        <button type="submit" class="btn-tb btn-tb-primary"><i class="bi bi-plus-circle"></i> Add Funds</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="section-card">
            <div class="section-head">
                <h3><i class="bi bi-people"></i> All Users</h3>
