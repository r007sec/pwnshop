<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- Reset Log Modal -->
<div class="modal-backdrop" id="resetLogModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-trash3-fill"></i></div>
        <div class="modal-title">Clear the audit log?</div>
        <p class="modal-body">
            All log entries will be permanently deleted. A single record of this action will remain.<br><br>
            This cannot be undone.
        </p>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="closeResetModal()">Cancel</button>
            <button class="btn-modal-confirm" onclick="submitResetLog()">Yes, clear it</button>
        </div>
    </div>
</div>
<form id="resetLogForm" method="POST" action="/admin/reset-log" style="display:none"></form>

<!-- Delete User Modal -->
<div class="modal-backdrop" id="deleteUserModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-person-x-fill"></i></div>
        <div class="modal-title">Delete user?</div>
        <p class="modal-body">
            You are about to permanently delete <strong id="deleteUserName"></strong>.<br><br>
            All their orders, cart items, reviews, wishlists, and messages will also be removed. This cannot be undone.
        </p>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
            <button class="btn-modal-confirm" id="deleteUserConfirmBtn">Yes, delete</button>
        </div>
    </div>
</div>

<script>
// ── Reset log modal ──
function openResetModal()  { document.getElementById('resetLogModal').classList.add('open'); }
function closeResetModal() { document.getElementById('resetLogModal').classList.remove('open'); }
function submitResetLog()  { document.getElementById('resetLogForm').submit(); }
document.getElementById('resetLogModal').addEventListener('click', function(e) {
    if (e.target === this) closeResetModal();
});

// ── Delete user modal ──
var _deleteUserId = null;
function openDeleteModal(id, username) {
    _deleteUserId = id;
    document.getElementById('deleteUserName').textContent = username;
    document.getElementById('deleteUserModal').classList.add('open');
}
function closeDeleteModal() {
    _deleteUserId = null;
    document.getElementById('deleteUserModal').classList.remove('open');
}
document.getElementById('deleteUserConfirmBtn').addEventListener('click', function() {
    if (_deleteUserId) document.getElementById('delete-form-' + _deleteUserId).submit();
});
document.getElementById('deleteUserModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
});

// ── Lab reset modal ──
function openLabResetModal() {
    document.getElementById('labResetModal').classList.add('open');
}
function closeLabResetModal() {
    document.getElementById('labResetModal').classList.remove('open');
}
function submitLabReset() {
    document.getElementById('labResetForm').submit();
}
document.getElementById('labResetModal').addEventListener('click', function(e) {
    if (e.target === this) closeLabResetModal();
});
</script>
<!-- Lab Reset Modal -->
<div class="modal-backdrop" id="labResetModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-arrow-repeat"></i></div>
        <div class="modal-title">Reset the entire lab?</div>
        <p class="modal-body">
            This will:<br>
            • Rebuild the database from fresh snapshot<br>
            • Clear all user uploads<br>
            • Reset all product inventories<br><br>
            <strong>This cannot be undone instantly, but the lab will auto-heal in 10 minutes.</strong>
        </p>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="closeLabResetModal()">Cancel</button>
            <button class="btn-modal-confirm" onclick="submitLabReset()">Yes, reset lab</button>
        </div>
    </div>
</div>
<form id="labResetForm" method="POST" action="/admin/lab-reset" style="display:none"></form>

    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
