                                <td class="td-mono" style="font-size:0.75rem;"><%= log.ip || '—' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <p style="font-size:0.72rem;color:var(--gray-500);margin-top:10px;">
                    Showing <%= auditLogs.length %> most recent entries.
