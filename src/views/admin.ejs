                </button>
            </div>

            <% if (!auditLogs || auditLogs.length === 0) { %>
                <div style="background:var(--gray-100);border-radius:10px;padding:28px;border:1.5px dashed var(--gray-200);text-align:center;color:var(--gray-500);font-size:0.85rem;">
